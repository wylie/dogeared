---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

type SearchResult = {
	title: string;
	subtitle: string;
	authors: string[];
	description: string;
	publisher: string;
	publishedDate: string;
	pageCount: number | null;
	categories: string[];
	language: string;
	thumbnail: string;
};

const query = Astro.url.searchParams.get("q")?.trim() ?? "";
const apiKey = import.meta.env.GOOGLE_BOOKS_API_KEY ?? "";

let results: SearchResult[] = [];
let errorMessage = "";

if (query && apiKey) {
	try {
		const params = new URLSearchParams({
			q: query,
			key: apiKey,
			maxResults: "10",
		});
		const response = await fetch(`https://www.googleapis.com/books/v1/volumes?${params.toString()}`);

		if (!response.ok) {
			throw new Error(`Request failed with status ${response.status}`);
		}

		const data = await response.json();
		const items = Array.isArray(data.items) ? data.items : [];

		results = items.map((item) => {
			const info = item.volumeInfo ?? {};

			return {
				title: info.title ?? "Untitled",
				subtitle: info.subtitle ?? "",
				authors: Array.isArray(info.authors) ? info.authors : [],
				description: info.description ?? "",
				publisher: info.publisher ?? "",
				publishedDate: info.publishedDate ?? "",
				pageCount: typeof info.pageCount === "number" ? info.pageCount : null,
				categories: Array.isArray(info.categories) ? info.categories : [],
				language: info.language ?? "",
				thumbnail: info.imageLinks?.thumbnail ?? "",
			};
		});
	} catch (error) {
		errorMessage = error instanceof Error ? error.message : "Unknown error";
	}
} else if (query && !apiKey) {
	errorMessage = "Missing Google Books API key.";
}
---

<Layout title="Search">
	<div slot="right">
		<h1>Search</h1>
		{!query && <p>Enter a search term to find books.</p>}
		{query && errorMessage && <p>Search failed: {errorMessage}</p>}
		{query && !errorMessage && results.length === 0 && <p>No results for "{query}".</p>}
		{query && !errorMessage && results.length > 0 && <p>Results for "{query}"</p>}

		<ul>
			{results.map((result) => (
				<li>
					<h2>{result.title}</h2>
					{result.thumbnail && <img src={result.thumbnail} alt={`${result.title} cover`} />}
					{result.subtitle && <p>Subtitle: {result.subtitle}</p>}
					<p>{result.authors.length > 0 ? result.authors.join(", ") : "Unknown author"}</p>
					{result.description && <p>Description: {result.description}</p>}
					{result.publisher && <p>Publisher: {result.publisher}</p>}
					{result.publishedDate && <p>Published: {result.publishedDate}</p>}
					{result.pageCount !== null && <p>Pages: {result.pageCount}</p>}
					{result.categories.length > 0 && <p>Categories: {result.categories.join(", ")}</p>}
					{result.language && <p>Language: {result.language}</p>}
				</li>
			))}
		</ul>
	</div>
</Layout>

<style>
</style>
