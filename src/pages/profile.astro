	function getGenreSuggestion(rawValue) {
		const query = normalizeProfileText(rawValue, 32).toLowerCase();
		if (!query || query.length < 2) return "";
		const current = new Set(editingGenres.map((genre) => genre.toLowerCase()));
		const startsWithMatches = GENRE_SUGGESTIONS.filter((genre) => {
			const lower = genre.toLowerCase();
			return lower.startsWith(query) && !current.has(lower);
		});
		if (startsWithMatches.length === 1) return startsWithMatches[0];
		if (startsWithMatches.length > 1) return "";

		const containsMatches = GENRE_SUGGESTIONS.filter((genre) => {
			const lower = genre.toLowerCase();
			return lower.includes(query) && !current.has(lower);
		});
		return containsMatches.length === 1 ? containsMatches[0] : "";
	}

	function applyGenreInlineAutocomplete(input) {
		if (!(input instanceof HTMLInputElement)) return;
		if (document.activeElement !== input) return;
		const base = normalizeProfileText(input.value, 32);
		if (!base) return;
		const suggestion = getGenreSuggestion(base);
		if (!suggestion) return;
		if (suggestion.toLowerCase() === base.toLowerCase()) return;
		const start = input.selectionStart ?? base.length;
		const end = input.selectionEnd ?? base.length;
		if (start !== end || start !== base.length) return;
		input.value = suggestion;
		input.setSelectionRange(base.length, suggestion.length);
	}

	function formatLocationLabel(input: { city: string; region: string; countryCode: string }) {
		return [input.city, input.region, input.countryCode].filter(Boolean).join(", ");
	}

	function uniqueLocationMatches(matches) {
		const seen = new Set<string>();
		const out: Array<{ label: string; city: string; region: string; countryCode: string }> = [];
		for (const match of matches) {
			const city = String(match?.city || "").trim();
			const region = String(match?.region || "").trim();
			const countryCode = String(match?.countryCode || "").trim().toUpperCase();
			const label = formatLocationLabel({ city, region, countryCode });
			if (!label) continue;
			const key = label.toLowerCase();
			if (seen.has(key)) continue;
			seen.add(key);
			out.push({ label, city, region, countryCode });
			if (out.length >= 8) break;
		}
		return out;
	}

	async function lookupLocationMatches(input) {
		const value = String(input || "").trim();
		if (!value) return [];
		const zipMatch = value.match(/\b(\d{5})(?:-\d{4})?\b/);
		const collected: Array<{ city: string; region: string; countryCode: string }> = [];
		if (zipMatch) {
			const response = await fetch(`https://api.zippopotam.us/us/${zipMatch[1]}`);
			if (response.ok) {
				const data = await response.json();
				const places = Array.isArray(data?.places) ? data.places : [];
				for (const place of places.slice(0, 5)) {
					const city = String(place?.["place name"] || "").trim();
					const state = String(place?.["state abbreviation"] || "").trim();
					if (city || state) {
						collected.push({ city, region: state, countryCode: "US" });
					}
				}
			}
		}

		const attempts = [];
		attempts.push(value);
		if (value.includes(",")) {
			attempts.push(value.split(",")[0].trim());
			attempts.push(value.replace(",", " ").replace(/\s+/g, " ").trim());
		}
		const uniqueAttempts = Array.from(new Set(attempts.filter(Boolean)));

		for (const query of uniqueAttempts) {
			const endpoint = new URL("https://geocoding-api.open-meteo.com/v1/search");
			endpoint.searchParams.set("name", query);
			endpoint.searchParams.set("count", "8");
			endpoint.searchParams.set("language", "en");
			endpoint.searchParams.set("format", "json");
			const response = await fetch(endpoint.toString());
			if (!response.ok) continue;
			const data = await response.json();
			const results = Array.isArray(data?.results) ? data.results : [];
			for (const result of results) {
				const city = String(result?.name || "").trim();
				const region = String(result?.admin1 || "").trim();
				const country = String(result?.country_code || "").trim().toUpperCase();
				if (!city && !region && !country) continue;
				collected.push({ city, region, countryCode: country });
			}
		}

		// Secondary fallback for city/state text searches.
		for (const query of uniqueAttempts) {
			const endpoint = new URL("https://nominatim.openstreetmap.org/search");
			endpoint.searchParams.set("q", query);
			endpoint.searchParams.set("format", "jsonv2");
			endpoint.searchParams.set("addressdetails", "1");
			endpoint.searchParams.set("limit", "1");
			const response = await fetch(endpoint.toString());
			if (!response.ok) continue;
			const data = await response.json();
			const results = Array.isArray(data) ? data : [];
			for (const result of results.slice(0, 5)) {
				const address = result?.address || {};
				const city = String(address.city || address.town || address.village || address.hamlet || "").trim();
				const region = String(address.state || "").trim();
				const countryCode = String(address.country_code || "").trim().toUpperCase();
				if (!city && !region && !countryCode) continue;
				collected.push({ city, region, countryCode });
			}
		}

		return uniqueLocationMatches(collected);
	}

