	function addGenreFromInput(rawValue) {
		const value = canonicalGenreLabel(rawValue);
		if (!value) return;
		const exists = editingGenres.some((genre) => genre.toLowerCase() === value.toLowerCase());
		if (exists || editingGenres.length >= 12) return;
		editingGenres.push(value);
