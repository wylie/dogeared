	async function checkUsernameAvailability(rawUsername) {
		const username = normalizeUsernameInput(rawUsername);
		const currentUsername = normalizeUsernameInput(profileInfo?.username);
		if (username && currentUsername && username === currentUsername) {
			showUsernameStatus("This is your current username.");
			return { ok: true, username, ownedByCurrentUser: true };
		}
		if (!username) {
			showUsernameStatus("Username is required.", true);
			return { ok: false, username };
		}
		if (username.length < 3) {
			showUsernameStatus("Use at least 3 characters.", true);
			return { ok: false, username };
		}
		showUsernameStatus("Checking username...");
		try {
			const userKey = getUserKey();
			const endpoint = new URL("/api/profile/username", window.location.origin);
			endpoint.searchParams.set("userKey", userKey);
			endpoint.searchParams.set("username", username);
			const response = await fetch(endpoint.toString());
			const data = await response.json();
			if (!response.ok) {
				showUsernameStatus(String(data?.error || "Could not validate username."), true);
				return { ok: false, username };
			}
			if (!data?.available) {
				showUsernameStatus(String(data?.reason || "Username is taken."), true);
				return { ok: false, username: String(data?.normalized || username) };
			}
			const normalized = String(data?.normalized || username);
			if (data?.ownedByCurrentUser) {
				showUsernameStatus("This is your current username.");
				return { ok: true, username: normalized, ownedByCurrentUser: true };
			}
			showUsernameStatus("Username available.");
			return { ok: true, username: normalized, ownedByCurrentUser: false };
		} catch {
			showUsernameStatus("Could not validate right now. Save will do a final check.");
			return { ok: true, username, unchecked: true };
		}
	}

	async function claimUsername(rawUsername) {
		const username = normalizeUsernameInput(rawUsername);
		const userKey = getUserKey();
		const response = await fetch("/api/profile/username", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ userKey, username })
		});
		const data = await response.json().catch(() => ({}));
		if (!response.ok) {
			return { ok: false, username, error: String(data?.error || "Failed to save username.") };
		}
		return { ok: true, username: String(data?.username || username) };
	}

