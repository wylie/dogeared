	function cleanupLikelyImportedFinishedDates() {
		const groups = new Map();
		for (const entry of entries) {
			if (entry?.status !== "finished") continue;
			const finishedDate = String(entry?.finishedDate || "").trim();
			if (!finishedDate) continue;
			const updatedAt = Number(entry?.updatedAt || 0);
			if (!Number.isFinite(updatedAt) || updatedAt <= 0) continue;
			const updatedDate = new Date(updatedAt).toISOString().slice(0, 10);
			if (updatedDate !== finishedDate) continue;
			const list = groups.get(finishedDate) || [];
			list.push(entry);
			groups.set(finishedDate, list);
		}

		let changed = false;
		for (const group of groups.values()) {
			if (group.length < 40) continue;
			for (const entry of group) {
				entry.finishedDate = "";
				changed = true;
			}
		}

		if (changed) {
			saveEntries();
		}
	}

