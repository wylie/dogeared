	async function lookupFavoriteBookMatches(input) {
		const query = String(input || "").trim();
		if (query.length < 2) return [];
		const endpoint = new URL("https://openlibrary.org/search.json");
		endpoint.searchParams.set("q", query);
		endpoint.searchParams.set("limit", "8");
		endpoint.searchParams.set("fields", "title,author_name,first_publish_year");
		const response = await fetch(endpoint.toString());
		if (!response.ok) return [];
		const data = await response.json();
		const docs = Array.isArray(data?.docs) ? data.docs : [];
		const seen = new Set();
		const matches = [];
		for (const doc of docs) {
			const title = normalizeProfileText(doc?.title, 120);
			const author = normalizeProfileText(Array.isArray(doc?.author_name) ? doc.author_name[0] : "", 80);
			const year = String(doc?.first_publish_year || "").trim();
			const formatted = normalizeFavoriteBookLabel(title, author);
			if (!formatted) continue;
			const key = formatted.toLowerCase();
			if (seen.has(key)) continue;
			seen.add(key);
			matches.push({ title, author, year, formatted });
			if (matches.length >= 8) break;
		}
		return matches;
	}

	async function resolveFavoriteBookValue(rawValue) {
		const query = normalizeProfileText(rawValue, 120);
		if (!query) return "";
		const direct = favoriteBookMatches.find((item) => item.formatted.toLowerCase() === query.toLowerCase());
		if (direct) return direct.formatted;
		const matches = await lookupFavoriteBookMatches(query);
		if (matches.length === 1) return matches[0].formatted;
		const exactTitle = matches.find((item) => item.title.toLowerCase() === query.toLowerCase());
		if (exactTitle) return exactTitle.formatted;
		const startsWith = matches.filter((item) => item.title.toLowerCase().startsWith(query.toLowerCase()));
		if (startsWith.length === 1) return startsWith[0].formatted;
		return query;
	}

	function scheduleFavoriteBookLookup(favoriteBookField, options = { immediate: false }) {
		if (!(favoriteBookField instanceof HTMLInputElement)) return;
		const query = String(favoriteBookField.value || "").trim();
		if (favoriteBookLookupTimer) {
			clearTimeout(favoriteBookLookupTimer);
			favoriteBookLookupTimer = 0;
		}
		if (!query) {
			favoriteBookMatches = [];
			favoriteBookField.dataset.resolvedFavoriteBook = "";
			showFavoriteBookStatus("");
			hideFavoriteBookOptions();
			return;
		}

		const lookupId = ++favoriteBookLookupSeq;
		const execute = async () => {
			showFavoriteBookStatus("Searching books...");
			try {
				const matches = await lookupFavoriteBookMatches(query);
				if (lookupId !== favoriteBookLookupSeq) return;
				favoriteBookMatches = matches;
				if (matches.length === 0) {
					favoriteBookField.dataset.resolvedFavoriteBook = "";
					showFavoriteBookStatus("No matches found. You can still type a book name.", true);
					hideFavoriteBookOptions();
					return;
				}
				const exact = matches.find((item) => item.formatted.toLowerCase() === query.toLowerCase());
				if (exact) {
					favoriteBookField.dataset.resolvedFavoriteBook = exact.formatted;
					showFavoriteBookStatus(`Matched: ${exact.formatted}`);
					hideFavoriteBookOptions();
					return;
				}
				favoriteBookField.dataset.resolvedFavoriteBook = "";
				showFavoriteBookStatus(`Select a book (${matches.length} matches).`);
				renderFavoriteBookOptions(favoriteBookField);
			} catch {
				if (lookupId !== favoriteBookLookupSeq) return;
				showFavoriteBookStatus("Book search failed. You can still type one manually.", true);
				hideFavoriteBookOptions();
			}
		};

		if (options.immediate) {
			void execute();
		} else {
			favoriteBookLookupTimer = window.setTimeout(() => {
				void execute();
			}, 300);
		}
	}

	function initializeProfileInfo() {
		profileInfo = loadProfileInfo();
		renderProfileInfo();
		setProfileEditMode(false);

		if (profileEditToggle instanceof HTMLButtonElement) {
			profileEditToggle.addEventListener("click", () => {
				fillProfileForm();
				setProfileEditMode(true);
			});
		}

		if (profileEditCancel instanceof HTMLButtonElement) {
			profileEditCancel.addEventListener("click", () => {
				setProfileEditMode(false);
			});
		}

		if (profileForm instanceof HTMLFormElement) {
			const avatarUrlField = profileForm.elements.namedItem("avatarUrl");
			const nameField = profileForm.elements.namedItem("name");
			const usernameField = profileForm.elements.namedItem("username");
			if (avatarUrlField instanceof HTMLInputElement) {
				avatarUrlField.addEventListener("change", () => {
					setEditingAvatar(avatarUrlField.value);
				});
				avatarUrlField.addEventListener("blur", () => {
					setEditingAvatar(avatarUrlField.value);
				});
			}

			if (nameField instanceof HTMLInputElement) {
				nameField.addEventListener("input", () => {
					if (!editingAvatar) renderAvatarPreview();
				});
			}

			if (usernameField instanceof HTMLInputElement) {
				usernameField.addEventListener("input", () => {
					const normalized = normalizeUsernameInput(usernameField.value);
					if (normalized !== usernameField.value) usernameField.value = normalized;
					showUsernameStatus("");
					if (usernameCheckTimer) clearTimeout(usernameCheckTimer);
					usernameCheckTimer = window.setTimeout(() => {
						if (!usernameField.value) return;
						void checkUsernameAvailability(usernameField.value);
					}, 350);
				});
				usernameField.addEventListener("blur", () => {
					if (usernameField.value) void checkUsernameAvailability(usernameField.value);
				});
			}

			if (profileAvatarRemove instanceof HTMLButtonElement) {
				profileAvatarRemove.addEventListener("click", () => {
					setEditingAvatar("");
					if (avatarUrlField instanceof HTMLInputElement) avatarUrlField.value = "";
					if (profileAvatarFile instanceof HTMLInputElement) profileAvatarFile.value = "";
				});
			}

			if (profileAvatarFile instanceof HTMLInputElement) {
				profileAvatarFile.addEventListener("change", async () => {
					const file = profileAvatarFile.files?.[0];
					if (!file) return;
					try {
						const dataUrl = await resizeImageFileToDataUrl(file);
						if (dataUrl) {
							setEditingAvatar(dataUrl);
							if (avatarUrlField instanceof HTMLInputElement) avatarUrlField.value = "";
						}
					} catch {
						// Ignore and keep current avatar.
					}
				});
			}

				if (profileGenreInput instanceof HTMLInputElement) {
					profileGenreInput.addEventListener("keydown", (event) => {
					if (event.key === "Tab") {
						const selectionStart = profileGenreInput.selectionStart ?? 0;
						const selectionEnd = profileGenreInput.selectionEnd ?? 0;
						if (selectionEnd > selectionStart) {
							event.preventDefault();
							profileGenreInput.setSelectionRange(selectionEnd, selectionEnd);
						}
					}
					if (event.key === "Enter" || event.key === ",") {
						event.preventDefault();
						addGenreFromInput(profileGenreInput.value);
					}
					});
					profileGenreInput.addEventListener("input", (event) => {
						if (event instanceof InputEvent && String(event.inputType || "").startsWith("delete")) {
							return;
						}
						applyGenreInlineAutocomplete(profileGenreInput);
					});
				}

			if (profileGenreSelected instanceof HTMLElement) {
				profileGenreSelected.addEventListener("click", (event) => {
					const target = event.target;
					if (!(target instanceof HTMLElement)) return;
					const removeValue = target.getAttribute("data-remove-genre");
					if (!removeValue) return;
					editingGenres = editingGenres.filter((genre) => genre.toLowerCase() !== removeValue.toLowerCase());
					renderGenreEditor();
				});
			}

			const locationField = profileForm.elements.namedItem("location");
			if (locationField instanceof HTMLInputElement) {
				locationField.addEventListener("input", () => {
					scheduleLocationLookup(locationField, { immediate: false });
				});
				locationField.addEventListener("keydown", (event) => {
					if (event.key === "ArrowDown" && locationMatches.length > 0) {
						event.preventDefault();
						if (!isLocationOptionsOpen()) {
							renderLocationOptions(locationField);
						}
						moveLocationActive(1);
						return;
					}
					if (event.key === "ArrowUp" && locationMatches.length > 0) {
						event.preventDefault();
						if (!isLocationOptionsOpen()) {
							renderLocationOptions(locationField);
						}
						moveLocationActive(-1);
						return;
					}
					if (event.key === "Escape" && isLocationOptionsOpen()) {
						event.preventDefault();
						hideLocationOptions();
						return;
					}
					if ((event.key === "Enter" || event.key === "Tab") && isLocationOptionsOpen() && locationMatches.length > 0) {
						event.preventDefault();
						const index = locationActiveIndex >= 0 ? locationActiveIndex : 0;
						commitLocationSelection(locationField, index);
					}
				});
				locationField.addEventListener("blur", () => {
					scheduleLocationLookup(locationField, { immediate: true });
					window.setTimeout(() => hideLocationOptions(), 160);
				});
					locationField.addEventListener("focus", () => {
						if (locationMatches.length > 1) renderLocationOptions(locationField);
					});
				}

				const favoriteBookField = profileForm.elements.namedItem("favoriteBook");
				if (favoriteBookField instanceof HTMLInputElement) {
					favoriteBookField.addEventListener("input", () => {
						favoriteBookField.dataset.resolvedFavoriteBook = "";
						scheduleFavoriteBookLookup(favoriteBookField, { immediate: false });
					});
					favoriteBookField.addEventListener("keydown", (event) => {
						if (event.key === "ArrowDown" && favoriteBookMatches.length > 0) {
							event.preventDefault();
							if (!isFavoriteBookOptionsOpen()) {
								renderFavoriteBookOptions(favoriteBookField);
							}
							moveFavoriteBookActive(1);
							return;
						}
						if (event.key === "ArrowUp" && favoriteBookMatches.length > 0) {
							event.preventDefault();
							if (!isFavoriteBookOptionsOpen()) {
								renderFavoriteBookOptions(favoriteBookField);
							}
							moveFavoriteBookActive(-1);
							return;
						}
						if (event.key === "Escape" && isFavoriteBookOptionsOpen()) {
							event.preventDefault();
							hideFavoriteBookOptions();
							return;
						}
						if ((event.key === "Enter" || event.key === "Tab") && isFavoriteBookOptionsOpen() && favoriteBookMatches.length > 0) {
							event.preventDefault();
							const index = favoriteBookActiveIndex >= 0 ? favoriteBookActiveIndex : 0;
							commitFavoriteBookSelection(favoriteBookField, index);
						}
					});
					favoriteBookField.addEventListener("blur", () => {
						scheduleFavoriteBookLookup(favoriteBookField, { immediate: true });
						window.setTimeout(() => hideFavoriteBookOptions(), 160);
						void (async () => {
							const resolved = await resolveFavoriteBookValue(favoriteBookField.value);
							favoriteBookField.value = resolved;
							favoriteBookField.dataset.resolvedFavoriteBook = resolved;
						})();
					});
					favoriteBookField.addEventListener("focus", () => {
						if (favoriteBookMatches.length > 0) renderFavoriteBookOptions(favoriteBookField);
					});
				}

			profileForm.addEventListener("submit", (event) => {
				event.preventDefault();
				if (!profileForm.reportValidity()) return;
				void (async () => {
					const formData = new FormData(profileForm);
					const requestedUsername = normalizeUsernameInput(formData.get("username"));
					const currentUsername = normalizeUsernameInput(profileInfo?.username);
						let resolvedUsername = requestedUsername;
						let resolvedFavoriteBook = normalizeProfileText(formData.get("favoriteBook"), 120);

						if (requestedUsername !== currentUsername) {
						const usernameCheck = await checkUsernameAvailability(requestedUsername);
						if (!usernameCheck.ok) return;
						const claim = await claimUsername(usernameCheck.username);
						if (!claim.ok) {
							showUsernameStatus(claim.error || "Username is unavailable.", true);
							return;
						}
							resolvedUsername = claim.username;
						}

						if (resolvedFavoriteBook) {
							const favoriteBookField = profileForm.elements.namedItem("favoriteBook");
							if (favoriteBookField instanceof HTMLInputElement) {
								if (favoriteBookField.dataset.resolvedFavoriteBook) {
									resolvedFavoriteBook = favoriteBookField.dataset.resolvedFavoriteBook;
								} else {
									resolvedFavoriteBook = await resolveFavoriteBookValue(resolvedFavoriteBook);
								}
								favoriteBookField.value = resolvedFavoriteBook;
								favoriteBookField.dataset.resolvedFavoriteBook = resolvedFavoriteBook;
							}
						}

						const next = normalizeProfileInfo({
							avatar: editingAvatar,
							name: formData.get("name"),
							username: resolvedUsername,
							location: formData.get("location"),
							readingGoal: formData.get("readingGoal"),
							favoriteBook: resolvedFavoriteBook,
								blurb: formData.get("blurb"),
								genres: editingGenres.join(", ")
							});
						const savedProfile = await saveProfileInfoToServer(next);
						profileInfo = saveProfileInfo(savedProfile);
						renderProfileInfo();
						showUsernameStatus("");
						setProfileEditMode(false);
					})();
				});
			}
		}

	function loadUpdates() {
		try {
			const parsed = JSON.parse(localStorage.getItem(UPDATES_KEY) || "[]");
			return Array.isArray(parsed) ? parsed : [];
		} catch {
			return [];
		}
	}

	function saveUpdates(updates) {
		localStorage.setItem(UPDATES_KEY, JSON.stringify(updates.slice(0, 200)));
	}

	function logShelfUpdate(entry, status) {
		if (!entry?.title) return;
		const updates = loadUpdates();
		updates.unshift({
			id: `upd_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
			timestamp: Date.now(),
			status: status || entry.status || "want_to_read",
			title: entry.title,
			author: entry.author || "",
			coverUrl: entry.coverUrl || "",
			format: entry.format || "",
			language: entry.language || ""
		});
		saveUpdates(updates);
	}

	function normalizeNumber(value) {
		const n = Number(value);
		if (!Number.isFinite(n) || n < 0) return 0;
		return Math.floor(n);
	}

	function progressPercent(entry) {
		const total = normalizeNumber(entry.totalPages);
		if (total <= 0) return 0;
		const current = normalizeNumber(entry.currentPage);
		return Math.max(0, Math.min(100, Math.round((current / total) * 100)));
	}

	function formatPublishedLabel(value) {
		const text = String(value || "").trim();
		if (!text) return "";
		if (/^\d{4}$/.test(text)) return text;
		if (/^\d{4}-\d{2}$/.test(text)) {
			const parsed = new Date(`${text}-01`);
			if (!Number.isFinite(parsed.getTime())) return text;
			return parsed.toLocaleDateString("en-US", {
				month: "long",
				year: "numeric"
			});
		}
		const parsed = new Date(text);
		if (!Number.isFinite(parsed.getTime())) return text;
		return parsed.toLocaleDateString("en-US", {
			month: "long",
			day: "numeric",
			year: "numeric"
		});
	}

	function formatFinishedLabel(value) {
		const text = String(value || "").trim();
		if (!text) return "";
		const parts = text.match(/^(\d{4})-(\d{2})-(\d{2})$/);
		if (parts) {
			const year = Number(parts[1]);
			const month = Number(parts[2]);
			const day = Number(parts[3]);
			const parsed = new Date(Date.UTC(year, month - 1, day));
			return parsed.toLocaleDateString("en-US", {
				month: "short",
				day: "numeric",
				year: "numeric",
				timeZone: "UTC"
			});
		}
		const parsed = new Date(text);
		if (!Number.isFinite(parsed.getTime())) return text;
		return parsed.toLocaleDateString("en-US", {
			month: "short",
			day: "numeric",
			year: "numeric"
		});
	}

	function escapeHtml(value) {
		return String(value || "")
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;")
			.replace(/"/g, "&quot;")
			.replace(/'/g, "&#39;");
	}

	function normalizeIsbn(value) {
		return String(value || "").replace(/[^0-9Xx]/g, "").toUpperCase();
	}

	function isValidIsbn(value) {
		const isbn = normalizeIsbn(value);
		return isbn.length === 10 || isbn.length === 13;
	}

	function coverFromIsbn(isbn13, isbn10, size = "M") {
		const clean13 = normalizeIsbn(isbn13);
		const clean10 = normalizeIsbn(isbn10);
		if (clean13.length === 13) return `https://covers.openlibrary.org/b/isbn/${clean13}-${size}.jpg`;
		if (clean10.length === 10) return `https://covers.openlibrary.org/b/isbn/${clean10}-${size}.jpg`;
		return "";
	}

	function hasLikelyInvalidIsbnCover(entry) {
		const url = String(entry?.coverUrl || "");
		if (!url.includes("covers.openlibrary.org/b/isbn/")) return false;
		return !isValidIsbn(entry?.isbn13) && !isValidIsbn(entry?.isbn10);
	}

	function normalizeText(value) {
		return String(value || "").trim().toLowerCase();
	}

	function canonicalizeTitle(value) {
		return normalizeText(value)
			.normalize("NFKD")
			.replace(/[\u0300-\u036f]/g, "")
			.replace(/\([^)]*\)/g, " ")
			.replace(/\b(abridged|unabridged|audio ?book|audiobook|kindle edition|paperback|hardcover|ebook|e-book|digital edition|color edition)\b/g, " ")
			.split(":")[0]
			.replace(/^(the|a|an)\s+/g, "")
			.replace(/[^a-z0-9\s]/g, " ")
			.replace(/\s+/g, " ")
			.trim();
	}

	function canonicalizeAuthor(value) {
		return normalizeText(value)
			.normalize("NFKD")
			.replace(/[\u0300-\u036f]/g, "")
			.replace(/^(by\s+)/, "")
			.replace(/[^a-z0-9\s]/g, " ")
			.replace(/\s+/g, " ")
			.trim();
	}

	function coverLookupKey(entry) {
		return `${canonicalizeTitle(entry?.title)}|${canonicalizeAuthor(entry?.author)}`;
	}

	function pickIsbn(values = []) {
		const cleaned = values.map((value) => normalizeIsbn(value)).filter(Boolean);
		const isbn13 = cleaned.find((value) => value.length === 13) || "";
		const isbn10 = cleaned.find((value) => value.length === 10) || "";
		return { isbn13, isbn10 };
	}

	async function fetchCoverByTitleAuthor(entry) {
		const title = String(entry?.title || "").trim();
		if (!title) return null;
		const author = String(entry?.author || "").trim();
		const targetTitle = canonicalizeTitle(title);
		const targetAuthor = canonicalizeAuthor(author);
		const targetAuthorLast = targetAuthor.split(" ").filter(Boolean).at(-1) || "";

		const endpoint = new URL("https://openlibrary.org/search.json");
		endpoint.searchParams.set("title", title);
		if (author) endpoint.searchParams.set("author", author);
		endpoint.searchParams.set("limit", "6");
		endpoint.searchParams.set("language", "eng");

		try {
			const response = await fetch(endpoint.toString(), {
				headers: { Accept: "application/json" }
			});
			if (!response.ok) return null;
			const data = await response.json();
			const docs = Array.isArray(data?.docs) ? data.docs : [];
			let best = null;
			let bestScore = -1;
			for (const doc of docs) {
				const docTitle = canonicalizeTitle(doc?.title);
				const docAuthorRaw = Array.isArray(doc?.author_name) ? String(doc.author_name[0] || "") : "";
				const docAuthor = canonicalizeAuthor(docAuthorRaw);
				const isbns = Array.isArray(doc?.isbn) ? doc.isbn : [];
				const { isbn13, isbn10 } = pickIsbn(isbns);
				const fromIsbn = coverFromIsbn(isbn13, isbn10);
				const coverId = Number(doc?.cover_i || 0);
				const coverUrl = fromIsbn || (coverId > 0 ? `https://covers.openlibrary.org/b/id/${coverId}-M.jpg` : "");
				if (!coverUrl) continue;

				let score = 0;
				if (docTitle === targetTitle) score += 4;
				if (docTitle && targetTitle && (docTitle.includes(targetTitle) || targetTitle.includes(docTitle))) score += 2;
				if (targetAuthor && docAuthor && docAuthor.includes(targetAuthor)) score += 2;
				if (targetAuthorLast && docAuthor && docAuthor.includes(targetAuthorLast)) score += 1;
				if (!targetAuthor) score += 1;

				if (score > bestScore) {
					bestScore = score;
					best = { coverUrl, isbn13, isbn10 };
				}
			}
			if (best && bestScore >= 2) {
				return best;
			}
		} catch {
			return null;
		}
		return null;
	}

	async function enrichMissingCovers() {
		if (coverLookupInFlight) return;
		coverLookupInFlight = true;
		try {
			const cache = loadCoverLookupCache();
			const missing = entries
				.filter((entry) => !entry.coverUrl || hasLikelyInvalidIsbnCover(entry))
				.filter((entry) => !coverFromIsbn(entry.isbn13, entry.isbn10))
				.slice(0, MAX_COVER_LOOKUPS_PER_PASS);
			const changed = [];

			for (const entry of missing) {
				const key = coverLookupKey(entry);
				if (!key || key === "|") continue;
				const cached = cache[key];
				if (cached?.missedAt && (Date.now() - Number(cached.missedAt)) < 300000) continue;
				if (cached?.coverUrl) {
					entry.coverUrl = String(cached.coverUrl || "");
					if (!entry.isbn13 && cached.isbn13) entry.isbn13 = cached.isbn13;
					if (!entry.isbn10 && cached.isbn10) entry.isbn10 = cached.isbn10;
					changed.push(entry);
					continue;
				}
				const resolved = await fetchCoverByTitleAuthor(entry);
				if (resolved?.coverUrl) {
					entry.coverUrl = resolved.coverUrl;
					if (!entry.isbn13 && resolved.isbn13) entry.isbn13 = resolved.isbn13;
					if (!entry.isbn10 && resolved.isbn10) entry.isbn10 = resolved.isbn10;
					cache[key] = {
						coverUrl: resolved.coverUrl,
						isbn13: resolved.isbn13 || "",
						isbn10: resolved.isbn10 || ""
					};
					changed.push(entry);
				} else {
					cache[key] = { missedAt: Date.now() };
				}
			}

			saveCoverLookupCache(cache);
			if (changed.length > 0) {
				saveEntries();
				renderLists();
				await Promise.allSettled(changed.map((entry) => syncEntryToServer(entry)));
			}
		} finally {
			coverLookupInFlight = false;
		}
	}

	function renderEntryCard(entry) {
		const author = entry.author ? `<p class="meta">${escapeHtml(entry.author)}</p>` : "";
		const formatMeta = entry.format ? `<p class="meta">${escapeHtml(entry.format)}${entry.language ? ` • ${escapeHtml(String(entry.language).toUpperCase())}` : ""}</p>` : "";
		const publishedMeta = entry.publishedDate ? `<p class="meta">Published: ${escapeHtml(formatPublishedLabel(entry.publishedDate))}</p>` : "";
		const total = normalizeNumber(entry.totalPages);
		const current = normalizeNumber(entry.currentPage);
		const percent = progressPercent(entry);
		const progress = (entry.status !== "want_to_read" && total > 0)
			? `<div class="progress-wrap"><div class="progress-bar" style="width:${percent}%"></div></div><p class="meta">${current}/${total} pages (${percent}%)</p>`
			: "";
		const progressEditor = entry.status === "reading"
			? `<div class="progress-editor">
				<label class="progress-label" for="progress-${escapeHtml(entry.id)}">Update progress</label>
				<div class="progress-controls">
					<input
						id="progress-${escapeHtml(entry.id)}"
						class="progress-input"
						type="number"
						min="0"
						${total > 0 ? `max="${total}"` : ""}
						step="1"
						inputmode="numeric"
						placeholder="Page #"
						value="${current}"
					/>
					<button type="button" class="secondary progress-save" data-action="update-progress">Save</button>
				</div>
			</div>`
			: "";
		const finishedDate = entry.finishedDate
			? `<p class="meta">Finished: ${escapeHtml(formatFinishedLabel(entry.finishedDate))}</p>`
			: "";
		const coverUrl = entry.coverUrl || coverFromIsbn(entry.isbn13, entry.isbn10);
		const cover = coverUrl
			? `<img class="cover" src="${escapeHtml(coverUrl)}" alt="" loading="lazy" data-cover-image onerror="this.hidden=true; if (this.nextElementSibling) this.nextElementSibling.hidden=false;" />
			   <div class="cover cover-placeholder" data-cover-placeholder hidden>
				   <span class="material-icons cover-placeholder-icon" aria-hidden="true">menu_book</span>
			   </div>`
			: `<div class="cover cover-placeholder">
				<span class="material-icons cover-placeholder-icon" aria-hidden="true">menu_book</span>
			</div>`;
		const actionButtons = [
			entry.status === "want_to_read" ? `<button type="button" data-action="start" class="secondary">Start Reading</button>` : "",
			entry.status === "reading" ? `<button type="button" data-action="finish" class="secondary">Mark Finished</button>` : ""
		].filter(Boolean).join("");
		const inlineActions = actionButtons
			? `<div class="entry-actions">${actionButtons}</div>`
			: "";

		return `
			<article class="entry-card" data-id="${escapeHtml(entry.id)}">
				<div class="card-menu-wrap">
					<button type="button" class="card-menu-trigger" data-action="toggle-card-menu" aria-expanded="false" aria-label="More actions">
						<span class="material-icons" aria-hidden="true">more_vert</span>
					</button>
					<div class="card-menu" hidden>
						<button type="button" class="card-menu-item danger-text" data-action="delete">Delete</button>
					</div>
				</div>
				<div class="cover-wrap">
					${cover}
				</div>
				<div class="card-body">
					<h3>${escapeHtml(entry.title)}</h3>
					${author}
					${formatMeta}
					${publishedMeta}
					${progress}
					${progressEditor}
					${finishedDate}
					${inlineActions}
				</div>
			</article>
		`;
	}

	function renderEmptyState(message) {
		return `<p class="empty-state">${escapeHtml(message)}</p>`;
	}

	function renderLists() {
		const wantToRead = entries
			.filter((entry) => entry.status === "want_to_read");
		const reading = entries
			.filter((entry) => entry.status === "reading");
		const finished = entries
			.filter((entry) => entry.status === "finished");
		const sortedWantToRead = sortEntries(wantToRead, "want_to_read");
		const sortedReading = sortEntries(reading, "reading");
		const sortedFinished = sortEntries(finished, "finished");

		wantToReadList.innerHTML = sortedWantToRead.length
			? sortedWantToRead.map(renderEntryCard).join("")
			: renderEmptyState("No books queued yet.");

		currentlyReadingList.innerHTML = sortedReading.length
			? sortedReading.map(renderEntryCard).join("")
			: renderEmptyState("No active books yet.");

		finishedList.innerHTML = sortedFinished.length
			? sortedFinished.map(renderEntryCard).join("")
			: renderEmptyState("No finished books yet.");

		for (const link of shelfFilterLinks) {
			const hash = link.getAttribute("href") || "";
			if (hash === "#want_to_read") link.textContent = `Want to Read (${wantToRead.length})`;
			if (hash === "#reading") link.textContent = `Currently Reading (${reading.length})`;
			if (hash === "#finished") link.textContent = `Read (${finished.length})`;
		}

		bindCoverFallbacks();
		renderGoalWidget();
	}

	function bindCoverFallbacks() {
		const images = Array.from(document.querySelectorAll("[data-cover-image]"));
		for (const image of images) {
			if (!(image instanceof HTMLImageElement)) continue;
			const wrap = image.closest(".cover-wrap");
			if (!(wrap instanceof HTMLElement)) continue;
			const placeholder = wrap.querySelector("[data-cover-placeholder]");
			if (!(placeholder instanceof HTMLElement)) continue;

			image.addEventListener("error", () => {
				image.hidden = true;
				placeholder.hidden = false;
			}, { once: true });

			if (image.complete && image.naturalWidth === 0) {
				image.hidden = true;
				placeholder.hidden = false;
			}
		}
	}

	function normalizeHashToTab(hash) {
		const value = String(hash || "").replace(/^#/, "").trim();
		if (value === "want_to_read" || value === "reading" || value === "finished") {
			return value;
		}
		return "want_to_read";
	}

	function syncSidebarFilterActive(nextTab) {
		for (const link of shelfFilterLinks) {
			const isActive = link.getAttribute("href") === `#${nextTab}`;
			link.classList.toggle("active", isActive);
			if (isActive) {
				link.setAttribute("aria-current", "true");
			} else {
				link.removeAttribute("aria-current");
			}
		}
	}

	function setActiveTab(nextTab) {
		activeTab = nextTab;
		for (const panel of shelfPanels) {
			panel.hidden = panel.dataset.panel !== nextTab;
		}
		syncSidebarFilterActive(nextTab);
	}

	function deleteEntry(entryId) {
		const existing = entries.find((entry) => entry.id === entryId);
		entries = entries.filter((entry) => entry.id !== entryId);
		saveEntries();
		renderLists();
		if (existing) {
			void deleteEntryFromServer(existing);
		}
	}

	function finishEntry(entryId) {
		const entry = entries.find((item) => item.id === entryId);
		if (!entry) return;
		const previousStatus = entry.status;
		entry.status = "finished";
		if (normalizeNumber(entry.totalPages) > 0) {
			entry.currentPage = normalizeNumber(entry.totalPages);
		}
		entry.finishedDate = entry.finishedDate || new Date().toISOString().slice(0, 10);
		entry.updatedAt = Date.now();
		saveEntries();
		if (previousStatus !== "finished") {
			logShelfUpdate(entry, "finished");
		}
		renderLists();
		void syncEntryToServer(entry);
	}

	function startReading(entryId) {
		const entry = entries.find((item) => item.id === entryId);
		if (!entry) return;
		const previousStatus = entry.status;
		entry.status = "reading";
		entry.finishedDate = "";
		entry.updatedAt = Date.now();
		saveEntries();
		if (previousStatus !== "reading") {
			logShelfUpdate(entry, "reading");
		}
		renderLists();
		void syncEntryToServer(entry);
	}

	function updateProgress(entryId, nextPageValue) {
		const entry = entries.find((item) => item.id === entryId);
		if (!entry) return;
		if (entry.status !== "reading") return;
		const total = normalizeNumber(entry.totalPages);
		let nextPage = normalizeNumber(nextPageValue);
		if (total > 0) {
			nextPage = Math.min(nextPage, total);
		}
		entry.currentPage = nextPage;
		entry.updatedAt = Date.now();
		saveEntries();
		renderLists();
		void syncEntryToServer(entry);
	}

	function handleListClick(event) {
		const target = event.target;
		if (!(target instanceof HTMLElement)) return;
		const actionTarget = target.closest("[data-action]");
		if (!(actionTarget instanceof HTMLElement)) return;
		const action = actionTarget.dataset.action;
		if (!action) return;
		const card = actionTarget.closest(".entry-card");
		if (!card) return;
		const entryId = card.getAttribute("data-id");
		if (!entryId) return;

		if (action === "toggle-card-menu") {
			const trigger = card.querySelector('[data-action="toggle-card-menu"]');
			const menu = card.querySelector(".card-menu");
			if (!(trigger instanceof HTMLElement) || !(menu instanceof HTMLElement)) return;
			const willOpen = menu.hidden;
			closeCardMenus(card);
			menu.hidden = !willOpen;
			trigger.setAttribute("aria-expanded", willOpen ? "true" : "false");
			return;
		}

		closeCardMenus();
		if (action === "delete") deleteEntry(entryId);
		if (action === "finish") finishEntry(entryId);
		if (action === "start") startReading(entryId);
		if (action === "update-progress") {
			const progressInput = card.querySelector(".progress-input");
			if (progressInput instanceof HTMLInputElement) {
				updateProgress(entryId, progressInput.value);
			}
		}
	}

	function handleListKeydown(event) {
		const target = event.target;
		if (!(target instanceof HTMLInputElement)) return;
		if (!target.classList.contains("progress-input")) return;
		if (event.key !== "Enter") return;
		event.preventDefault();
		const card = target.closest(".entry-card");
		if (!card) return;
		const entryId = card.getAttribute("data-id");
		if (!entryId) return;
		updateProgress(entryId, target.value);
	}

	function closeCardMenus(exceptCard = null) {
		const menus = Array.from(document.querySelectorAll(".card-menu"));
		for (const menu of menus) {
			if (!(menu instanceof HTMLElement)) continue;
			const card = menu.closest(".entry-card");
			if (exceptCard && card === exceptCard) continue;
			menu.hidden = true;
			const trigger = card?.querySelector?.('[data-action="toggle-card-menu"]');
			if (trigger instanceof HTMLElement) {
				trigger.setAttribute("aria-expanded", "false");
			}
		}
	}

	function setupSortControls() {
		loadListSorts();
		syncSortInputs();

		if (wantToReadSort instanceof HTMLSelectElement) {
			wantToReadSort.addEventListener("change", () => {
				listSorts.want_to_read = normalizeSortValue(wantToReadSort.value, "want_to_read");
				saveListSorts();
				renderLists();
			});
		}
		if (readingSort instanceof HTMLSelectElement) {
			readingSort.addEventListener("change", () => {
				listSorts.reading = normalizeSortValue(readingSort.value, "reading");
				saveListSorts();
				renderLists();
			});
		}
		if (finishedSort instanceof HTMLSelectElement) {
			finishedSort.addEventListener("change", () => {
				listSorts.finished = normalizeSortValue(finishedSort.value, "finished");
				saveListSorts();
				renderLists();
			});
		}
	}

	for (const link of shelfFilterLinks) {
		link.addEventListener("click", (event) => {
			event.preventDefault();
			const tabName = normalizeHashToTab(link.getAttribute("href"));
			history.replaceState(null, "", `#${tabName}`);
			setActiveTab(tabName);
		});
	}

	window.addEventListener("hashchange", () => {
		setActiveTab(normalizeHashToTab(window.location.hash));
	});

	document.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) return;
		if (target.closest(".card-menu-wrap")) return;
		closeCardMenus();
	});

	wantToReadList.addEventListener("click", handleListClick);
	currentlyReadingList.addEventListener("click", handleListClick);
	finishedList.addEventListener("click", handleListClick);
	wantToReadList.addEventListener("keydown", handleListKeydown);
	currentlyReadingList.addEventListener("keydown", handleListKeydown);
	finishedList.addEventListener("keydown", handleListKeydown);

	initializeProfileInfo();
	setupSortControls();
	loadEntries();
	cleanupLikelyImportedFinishedDates();
	renderLists();
	setActiveTab(normalizeHashToTab(window.location.hash));
	void enrichMissingCovers();
	void hydrateProfileInfoFromServer();
	void hydrateEntriesFromServer();
	}
</script>

