---
import Layout from '../layouts/Layout.astro';
import { resolveUserBySession } from '../lib/auth';

export const prerender = false;

const sectionLinks = [
	{ id: "reading", label: "Currently Reading" },
	{ id: "want_to_read", label: "Want to Read" },
	{ id: "finished", label: "Read" }
];
const session = await resolveUserBySession(Astro.request);
const isAuthenticated = !!session?.userId;
---

<Layout title="Profile" sectionLinks={sectionLinks}>
	<div slot="right" class="reads-page" data-authenticated={String(isAuthenticated)}>
		{!isAuthenticated && (
			<section class="auth-required">
				<h1>Profile</h1>
				<p class="subhead">Log in to view your reading history, shelves, and progress.</p>
				<p><a href="/settings#account-settings" class="auth-link">Log In or Sign Up</a></p>
			</section>
		)}
		{isAuthenticated && (
		<>
		<h1>Profile</h1>
		<p class="subhead">Your reading history, shelves, and progress.</p>

		<section class="profile-details" aria-labelledby="profile-details-title">
			<div class="profile-details-head">
				<h2 id="profile-details-title">About You</h2>
				<button type="button" id="profile-edit-toggle" class="secondary">Edit Profile</button>
			</div>

			<div id="profile-view" class="profile-view"></div>

				<form id="profile-form" class="profile-form" hidden>
					<div class="profile-grid">
						<label class="full-span">
							Avatar
							<div class="avatar-editor">
								<div id="profile-avatar-preview" class="avatar-preview"></div>
								<div class="avatar-controls">
									<input type="text" name="avatarUrl" maxlength="500" placeholder="Image URL (https://...)" />
									<div class="avatar-buttons">
										<input id="profile-avatar-file" type="file" accept="image/*" />
										<button type="button" id="profile-avatar-remove" class="secondary">Remove</button>
									</div>
									<input type="hidden" name="avatar" />
									<p class="field-hint">Upload an image or paste an image URL.</p>
								</div>
							</div>
						</label>
						<label>
							Name
							<input type="text" name="name" maxlength="80" placeholder="e.g. Wylie Reader" required />
						</label>
						<label>
							Username
							<input type="text" name="username" maxlength="40" placeholder="e.g. wylie_reads" required />
							<p id="profile-username-status" class="field-status" hidden></p>
						</label>
						<label>
							Location
							<div class="location-autocomplete">
								<input type="text" name="location" maxlength="80" autocomplete="off" placeholder="City, State or ZIP (e.g. Austin, TX or 78701)" required />
								<div id="profile-location-options" class="location-options" hidden></div>
							</div>
							<p id="profile-location-status" class="location-status" hidden></p>
						</label>
					<label>
						Reading Goal
						<input type="text" name="readingGoal" maxlength="80" placeholder="e.g. 24 books in 2026" />
					</label>
					<label>
						Favorite Book
						<div class="favorite-book-autocomplete">
							<input type="text" name="favoriteBook" maxlength="120" autocomplete="off" placeholder="Search title or author" />
							<div id="profile-favorite-book-options" class="favorite-book-options" hidden></div>
						</div>
						<p id="profile-favorite-book-status" class="field-status" hidden></p>
					</label>
						<label>
							Favorite Genres
							<div class="genre-editor">
								<div class="genre-input-row">
									<input id="profile-genre-input" type="text" placeholder="Start typing a genre" />
								</div>
								<input type="hidden" name="genres" />
								<p class="field-hint">Add one at a time. Press Enter or comma.</p>
								<div id="profile-genre-selected" class="genre-list genre-edit-list"></div>
							</div>
						</label>
					</div>
				<label>
					Blurb
					<textarea name="blurb" rows="3" maxlength="400" placeholder="Tell people about your reading taste."></textarea>
				</label>
				<div class="profile-actions">
					<button type="submit">Save Profile</button>
					<button type="button" id="profile-edit-cancel" class="secondary">Cancel</button>
				</div>
			</form>
		</section>

		<section id="goal-progress-widget" class="goal-widget" aria-live="polite"></section>

		<section class="list-section" data-panel="want_to_read" id="want_to_read">
			<div class="list-section-head">
				<h2 id="section-want-to-read">Want to Read</h2>
				<label class="list-sort">
					<span>Sort</span>
					<select id="sort-want-to-read">
						<option value="date_added_desc">Date Added</option>
						<option value="name_asc">Name</option>
						<option value="author_asc">Author</option>
						<option value="date_finished_desc">Date Finished</option>
					</select>
				</label>
			</div>
			<div id="want-to-read-list" class="entry-list"></div>
		</section>

		<section class="list-section" data-panel="reading" id="reading" hidden>
			<div class="list-section-head">
				<h2 id="section-reading">Currently Reading</h2>
				<label class="list-sort">
					<span>Sort</span>
					<select id="sort-reading">
						<option value="date_added_desc">Date Added</option>
						<option value="name_asc">Name</option>
						<option value="author_asc">Author</option>
						<option value="date_finished_desc">Date Finished</option>
					</select>
				</label>
			</div>
			<div id="currently-reading-list" class="entry-list"></div>
		</section>

		<section class="list-section" data-panel="finished" id="finished" hidden>
			<div class="list-section-head">
				<h2 id="section-finished">Finished</h2>
				<label class="list-sort">
					<span>Sort</span>
					<select id="sort-finished">
						<option value="date_finished_desc">Date Finished</option>
						<option value="date_added_desc">Date Added</option>
						<option value="name_asc">Name</option>
						<option value="author_asc">Author</option>
					</select>
				</label>
			</div>
			<div id="finished-list" class="entry-list"></div>
		</section>
		</>
		)}
	</div>
</Layout>

<script>
	const profilePageRoot = document.querySelector(".reads-page");
	if (profilePageRoot?.dataset.authenticated === "true") {
	const STORAGE_KEY = "dogeared:myreads";
	const UPDATES_KEY = "dogeared:updates";
	const USER_KEY_STORAGE_KEY = "dogeared:user-key";
	const PROFILE_INFO_KEY = "dogeared:profile-info";
	const COVER_CACHE_KEY = "dogeared:cover-lookup-cache";
	const LIST_SORTS_KEY = "dogeared:profile-list-sorts";
	const MAX_COVER_LOOKUPS_PER_PASS = 40;
	let entries = [];
	let coverLookupInFlight = false;
	let profileInfo = null;

	const wantToReadList = document.getElementById("want-to-read-list");
	const currentlyReadingList = document.getElementById("currently-reading-list");
	const finishedList = document.getElementById("finished-list");
	const wantToReadSort = document.getElementById("sort-want-to-read");
	const readingSort = document.getElementById("sort-reading");
	const finishedSort = document.getElementById("sort-finished");
	const profileView = document.getElementById("profile-view");
	const goalProgressWidget = document.getElementById("goal-progress-widget");
	const profileForm = document.getElementById("profile-form");
	const profileEditToggle = document.getElementById("profile-edit-toggle");
	const profileEditCancel = document.getElementById("profile-edit-cancel");
	const profileGenreInput = document.getElementById("profile-genre-input");
	const profileGenreSelected = document.getElementById("profile-genre-selected");
	const profileUsernameStatus = document.getElementById("profile-username-status");
	const profileLocationStatus = document.getElementById("profile-location-status");
	const profileLocationOptions = document.getElementById("profile-location-options");
	const profileFavoriteBookStatus = document.getElementById("profile-favorite-book-status");
	const profileFavoriteBookOptions = document.getElementById("profile-favorite-book-options");
	const profileAvatarPreview = document.getElementById("profile-avatar-preview");
	const profileAvatarFile = document.getElementById("profile-avatar-file");
	const profileAvatarRemove = document.getElementById("profile-avatar-remove");
	const shelfPanels = Array.from(document.querySelectorAll("[data-panel]"));
	const shelfFilterLinks = Array.from(document.querySelectorAll('.quick-links a[href^="#"]'));
	let activeTab = "want_to_read";
	let editingGenres = [];
	let editingAvatar = "";
	let usernameCheckTimer = 0;
	let locationLookupTimer = 0;
	let locationLookupSeq = 0;
	let locationMatches = [];
	let locationActiveIndex = -1;
	let favoriteBookLookupTimer = 0;
	let favoriteBookLookupSeq = 0;
	let favoriteBookMatches = [];
	let favoriteBookActiveIndex = -1;
	let listSorts = {
		want_to_read: "date_added_desc",
		reading: "date_added_desc",
		finished: "date_finished_desc"
	};
	const GENRE_SUGGESTIONS = [
		"Fantasy",
		"Sci-Fi",
		"Mystery",
		"Thriller",
		"Romance",
		"Historical Fiction",
		"Horror",
		"Literary Fiction",
		"Classics",
		"Young Adult",
		"Memoir",
		"Biography",
		"Self-Help",
		"Business",
		"History",
		"Philosophy",
		"Psychology",
		"Science",
		"Politics",
		"Poetry",
		"Graphic Novel",
		"Manga",
		"Comics",
		"Children's",
		"Religion & Spirituality",
		"Travel",
		"Cooking"
	];
	const GENRE_ALIASES = new Map([
		["science fiction", "Sci-Fi"],
		["scifi", "Sci-Fi"],
		["sci fi", "Sci-Fi"],
		["sci-fi", "Sci-Fi"]
	]);

	function getUserKey() {
		try {
			const existing = String(localStorage.getItem(USER_KEY_STORAGE_KEY) || "").trim();
			if (existing) return existing;
			const created = `usr_${Date.now()}_${Math.random().toString(36).slice(2, 10)}`;
			localStorage.setItem(USER_KEY_STORAGE_KEY, created);
			return created;
		} catch {
			return `usr_fallback_${Math.random().toString(36).slice(2, 10)}`;
		}
	}

	async function syncEntryToServer(entry) {
		const userKey = getUserKey();
		await fetch("/api/shelf/entries", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ userKey, entry })
		});
	}

	async function deleteEntryFromServer(entry) {
		const userKey = getUserKey();
		await fetch("/api/shelf/entries", {
			method: "DELETE",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ userKey, entry })
		});
	}

	async function hydrateProfileInfoFromServer() {
		const userKey = getUserKey();
		try {
			const endpoint = new URL("/api/profile/info", window.location.origin);
			endpoint.searchParams.set("userKey", userKey);
			const response = await fetch(endpoint.toString());
			const data = await response.json().catch(() => ({}));
			if (!response.ok || !data?.profile) return false;
			profileInfo = saveProfileInfo(data.profile);
			renderProfileInfo();
			return true;
		} catch {
			return false;
		}
	}

	async function saveProfileInfoToServer(nextProfile) {
		const userKey = getUserKey();
		const response = await fetch("/api/profile/info", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ userKey, profile: nextProfile })
		});
		const data = await response.json().catch(() => ({}));
		if (!response.ok) {
			throw new Error(String(data?.error || "Failed to save profile info."));
		}
		return data?.profile || nextProfile;
	}

	async function hydrateEntriesFromServer() {
		const userKey = getUserKey();
		const response = await fetch(`/api/shelf/entries?userKey=${encodeURIComponent(userKey)}`);
		if (!response.ok) return;
		const data = await response.json();
		if (!Array.isArray(data?.entries)) return;
		entries = data.entries;
		for (const entry of entries) {
			if (normalizeNumber(entry?.addedAt) > 0) continue;
			entry.addedAt = entryAddedTimestamp(entry);
		}
		saveEntries();
		renderLists();
		void enrichMissingCovers();
	}

	function loadEntries() {
		try {
			const parsed = JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
			entries = Array.isArray(parsed) ? parsed : [];
		} catch {
			entries = [];
		}
		let changed = false;
		for (const entry of entries) {
			const existingAddedAt = normalizeNumber(entry?.addedAt);
			if (existingAddedAt > 0) continue;
			entry.addedAt = entryAddedTimestamp(entry);
			changed = true;
		}
		if (changed) {
			try {
				saveEntries();
			} catch {
				// Ignore localStorage quota errors during non-critical field backfill.
			}
		}
	}

	function saveEntries() {
		localStorage.setItem(STORAGE_KEY, JSON.stringify(entries));
	}

	function normalizeSortValue(value, panel) {
		const allowed = ["date_added_desc", "date_finished_desc", "name_asc", "author_asc"];
		const next = String(value || "").trim();
		if (allowed.includes(next)) return next;
		return panel === "finished" ? "date_finished_desc" : "date_added_desc";
	}

	function loadListSorts() {
		try {
			const parsed = JSON.parse(localStorage.getItem(LIST_SORTS_KEY) || "{}");
			listSorts = {
				want_to_read: normalizeSortValue(parsed?.want_to_read, "want_to_read"),
				reading: normalizeSortValue(parsed?.reading, "reading"),
				finished: normalizeSortValue(parsed?.finished, "finished")
			};
		} catch {
			listSorts = {
				want_to_read: "date_added_desc",
				reading: "date_added_desc",
				finished: "date_finished_desc"
			};
		}
	}

	function saveListSorts() {
		localStorage.setItem(LIST_SORTS_KEY, JSON.stringify(listSorts));
	}

	function syncSortInputs() {
		if (wantToReadSort instanceof HTMLSelectElement) {
			wantToReadSort.value = normalizeSortValue(listSorts.want_to_read, "want_to_read");
		}
		if (readingSort instanceof HTMLSelectElement) {
			readingSort.value = normalizeSortValue(listSorts.reading, "reading");
		}
		if (finishedSort instanceof HTMLSelectElement) {
			finishedSort.value = normalizeSortValue(listSorts.finished, "finished");
		}
	}

	function loadCoverLookupCache() {
		try {
			const parsed = JSON.parse(localStorage.getItem(COVER_CACHE_KEY) || "{}");
			return parsed && typeof parsed === "object" ? parsed : {};
		} catch {
			return {};
		}
	}

	function saveCoverLookupCache(cache) {
		try {
			localStorage.setItem(COVER_CACHE_KEY, JSON.stringify(cache));
		} catch {
			// Ignore cache write failures.
		}
	}

	function normalizeProfileText(value, maxLength = 400) {
		return String(value || "").replace(/\s+/g, " ").trim().slice(0, maxLength);
	}

	function parseGenres(value) {
		const input = String(value || "");
		const parts = input
			.split(",")
			.map((item) => canonicalGenreLabel(item))
			.filter(Boolean);
		const dedupe = new Set();
		const genres = [];
		for (const part of parts) {
			const key = part.toLowerCase();
			if (dedupe.has(key)) continue;
			dedupe.add(key);
			genres.push(part);
			if (genres.length >= 12) break;
		}
		return genres;
	}

	function canonicalGenreLabel(value) {
		const normalized = normalizeProfileText(value, 32).toLowerCase();
		if (!normalized) return "";
		const direct = GENRE_SUGGESTIONS.find((genre) => genre.toLowerCase() === normalized);
		if (direct) return direct;
		const alias = GENRE_ALIASES.get(normalized);
		if (alias) return alias;
		return "";
	}

	function normalizeProfileInfo(input) {
		const genres = Array.isArray(input?.genres)
			? parseGenres(input.genres.join(","))
			: parseGenres(input?.genres || "");
		const avatar = normalizeAvatarValue(input?.avatar || input?.avatarUrl);
		return {
			avatar,
			name: normalizeProfileText(input?.name, 80),
			username: normalizeProfileText(input?.username, 40).replace(/^@+/, ""),
			location: normalizeProfileText(input?.location, 80),
			readingGoal: normalizeProfileText(input?.readingGoal, 80),
			favoriteBook: normalizeProfileText(input?.favoriteBook, 120),
			blurb: normalizeProfileText(input?.blurb, 400),
			genres
		};
	}

	function loadProfileInfo() {
		try {
			const parsed = JSON.parse(localStorage.getItem(PROFILE_INFO_KEY) || "{}");
			return normalizeProfileInfo(parsed);
		} catch {
			return normalizeProfileInfo({});
		}
	}

	function saveProfileInfo(nextProfile) {
		const normalized = normalizeProfileInfo(nextProfile);
		localStorage.setItem(PROFILE_INFO_KEY, JSON.stringify(normalized));
		return normalized;
	}

	function profileLabel(value, fallback = "Not set yet") {
		const text = String(value || "").trim();
		return text || fallback;
	}

	function normalizeAvatarValue(value) {
		const text = String(value || "").trim();
		if (!text) return "";
		if (text.startsWith("data:image/")) return text;
		if (/^https?:\/\//i.test(text)) return text;
		return "";
	}

	function profileInitials() {
		const name = String(profileInfo?.name || "").trim();
		if (!name) return "R";
		const parts = name.split(/\s+/).filter(Boolean);
		if (parts.length === 1) return parts[0].slice(0, 1).toUpperCase();
		return `${parts[0][0] || ""}${parts[1][0] || ""}`.toUpperCase();
	}

	function renderProfileInfo() {
		if (!(profileView instanceof HTMLElement)) return;
		const genres = Array.isArray(profileInfo?.genres) ? profileInfo.genres : [];
		const avatar = normalizeAvatarValue(profileInfo?.avatar);
		const location = normalizeProfileText(profileInfo?.location, 80);
		const readingGoal = normalizeProfileText(profileInfo?.readingGoal, 80);
		const favoriteBook = normalizeProfileText(profileInfo?.favoriteBook, 120);
		const blurb = normalizeProfileText(profileInfo?.blurb, 400);

		const details = [
			location ? `<p class="meta"><strong>Location:</strong> ${escapeHtml(location)}</p>` : "",
			readingGoal ? `<p class="meta"><strong>Reading Goal:</strong> ${escapeHtml(readingGoal)}</p>` : "",
			favoriteBook ? `<p class="meta"><strong>Favorite Book:</strong> ${escapeHtml(favoriteBook)}</p>` : "",
			blurb ? `<p class="profile-blurb">${escapeHtml(blurb)}</p>` : "",
			genres.length > 0
				? `<div class="genre-list">${genres.map((genre) => `<span class="genre-chip">${escapeHtml(genre)}</span>`).join("")}</div>`
				: ""
		].filter(Boolean).join("");

		profileView.innerHTML = `
			<div class="profile-view-head">
				<div class="profile-avatar">
					${avatar
						? `<img class="profile-avatar-image" src="${escapeHtml(avatar)}" alt="" loading="lazy" />`
						: `<span class="profile-avatar-fallback" aria-hidden="true">${escapeHtml(profileInitials())}</span>`}
				</div>
				<div>
					<h3>${escapeHtml(profileLabel(profileInfo?.name, "Reader"))}</h3>
					<p class="meta">@${escapeHtml(profileLabel(profileInfo?.username, "username"))}</p>
				</div>
			</div>
			${details}
		`;
		renderGoalWidget();
	}

	function parseReadingGoalConfig(value) {
		const text = String(value || "").trim();
		const goalMatch = text.match(/\d{1,4}/);
		const goal = goalMatch ? Math.floor(Number(goalMatch[0])) : 0;
		const yearMatch = text.match(/\b(19|20)\d{2}\b/);
		const currentYear = new Date().getFullYear();
		const year = yearMatch ? Number(yearMatch[0]) : currentYear;
		return {
			goal: Number.isFinite(goal) && goal > 0 ? goal : 0,
			year
		};
	}

	function finishedYearForEntry(entry) {
		const finishedDate = String(entry?.finishedDate || "").trim();
		const dateYearMatch = finishedDate.match(/\b(19|20)\d{2}\b/);
		if (dateYearMatch) return Number(dateYearMatch[0]);
		return 0;
	}

	function entryAddedTimestamp(entry) {
		const explicit = normalizeNumber(entry?.addedAt);
		if (explicit > 0) return explicit;
		const updated = normalizeNumber(entry?.updatedAt);
		const id = String(entry?.id || "");
		const idMatch = id.match(/^book_(\d{10,13})_/);
		if (idMatch) {
			const fromId = Number(idMatch[1]);
			if (Number.isFinite(fromId) && fromId > 0) return fromId;
		}
		return updated > 0 ? updated : Date.now();
	}

	function finishedTimestamp(entry) {
		const finishedDate = String(entry?.finishedDate || "").trim();
		if (!finishedDate) return 0;
		const parts = finishedDate.match(/^(\d{4})-(\d{2})-(\d{2})$/);
		if (!parts) {
			const parsed = Date.parse(finishedDate);
			return Number.isFinite(parsed) ? parsed : 0;
		}
		const year = Number(parts[1]);
		const month = Number(parts[2]);
		const day = Number(parts[3]);
		return Date.UTC(year, month - 1, day);
	}

	function compareText(a, b, selector) {
		const aText = normalizeProfileText(selector(a), 160).toLowerCase();
		const bText = normalizeProfileText(selector(b), 160).toLowerCase();
		if (aText < bText) return -1;
		if (aText > bText) return 1;
		return 0;
	}

	function sortEntries(items, panel) {
		const mode = normalizeSortValue(listSorts[panel], panel);
		const list = [...items];
		list.sort((a, b) => {
			if (mode === "name_asc") {
				const byName = compareText(a, b, (item) => item?.title);
				if (byName !== 0) return byName;
				return compareText(a, b, (item) => item?.author);
			}
			if (mode === "author_asc") {
				const byAuthor = compareText(a, b, (item) => item?.author);
				if (byAuthor !== 0) return byAuthor;
				return compareText(a, b, (item) => item?.title);
			}
			if (mode === "date_finished_desc") {
				const byFinished = finishedTimestamp(b) - finishedTimestamp(a);
				if (byFinished !== 0) return byFinished;
				return entryAddedTimestamp(b) - entryAddedTimestamp(a);
			}
			const byAdded = entryAddedTimestamp(b) - entryAddedTimestamp(a);
			if (byAdded !== 0) return byAdded;
			return compareText(a, b, (item) => item?.title);
		});
		return list;
	}

	function finishedCountForGoalYear(year) {
		return entries.filter((entry) => (
			entry?.status === "finished" && finishedYearForEntry(entry) === year
		)).length;
	}

	function renderGoalWidget() {
		if (!(goalProgressWidget instanceof HTMLElement)) return;
		const goalConfig = parseReadingGoalConfig(profileInfo?.readingGoal);
		const goal = goalConfig.goal;
		const goalYear = goalConfig.year;
		if (goal <= 0) {
			goalProgressWidget.innerHTML = `
				<div class="goal-widget-card">
					<h2>Reading Goal Progress</h2>
					<p class="goal-meta">Add a numeric reading goal in About You to track progress here.</p>
				</div>
			`;
			return;
		}

		const finished = finishedCountForGoalYear(goalYear);
		const percent = Math.max(0, Math.min(100, Math.round((finished / goal) * 100)));
		const remaining = Math.max(0, goal - finished);
		const goalReached = finished >= goal;

		goalProgressWidget.innerHTML = `
			<div class="goal-widget-card">
				<div class="goal-head">
					<h2>Reading Goal Progress</h2>
					<p class="goal-value">${finished} / ${goal} books</p>
				</div>
				<div class="goal-progress-track" aria-hidden="true">
					<div class="goal-progress-fill" style="width:${percent}%"></div>
				</div>
