	function moveLocationActive(delta) {
		if (!isLocationOptionsOpen() || locationMatches.length === 0) return;
		const max = locationMatches.length - 1;
		if (locationActiveIndex < 0) {
			locationActiveIndex = delta > 0 ? 0 : max;
		} else {
			locationActiveIndex += delta;
			if (locationActiveIndex < 0) locationActiveIndex = max;
			if (locationActiveIndex > max) locationActiveIndex = 0;
		}
		if (profileLocationOptions instanceof HTMLElement) {
			const items = Array.from(profileLocationOptions.querySelectorAll(".location-option"));
			for (const [index, item] of items.entries()) {
				item.classList.toggle("is-active", index === locationActiveIndex);
			}
			const active = items[locationActiveIndex];
			if (active) active.scrollIntoView({ block: "nearest" });
		}
	}

	function renderLocationOptions(locationField) {
		if (!(profileLocationOptions instanceof HTMLElement)) return;
		if (locationMatches.length === 0) {
			hideLocationOptions();
			return;
		}
		locationActiveIndex = 0;
		profileLocationOptions.innerHTML = locationMatches.map((match, index) => (
			`<button type="button" class="location-option ${index === 0 ? "is-active" : ""}" data-location-index="${index}">${escapeHtml(match.label)}</button>`
		)).join("");
		profileLocationOptions.hidden = false;
		profileLocationOptions.onclick = (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			const rawIndex = target.getAttribute("data-location-index");
			if (rawIndex == null) return;
			const index = Number(rawIndex);
			commitLocationSelection(locationField, index);
		};
	}

	function scheduleLocationLookup(locationField, options = { immediate: false }) {
		if (!(locationField instanceof HTMLInputElement)) return;
		const query = String(locationField.value || "").trim();
		if (locationLookupTimer) {
			clearTimeout(locationLookupTimer);
			locationLookupTimer = 0;
		}
		if (!query) {
			locationMatches = [];
			locationField.dataset.resolvedLocation = "";
			showLocationStatus("");
			hideLocationOptions();
			return;
		}

		const lookupId = ++locationLookupSeq;
		const execute = async () => {
			showLocationStatus("Matching location...");
			try {
				const matches = await lookupLocationMatches(query);
				if (lookupId !== locationLookupSeq) return;
				locationMatches = matches;
				if (matches.length === 0) {
					locationField.dataset.resolvedLocation = "";
					showLocationStatus("No match found. Try a fuller city/state or 5-digit ZIP.", true);
					hideLocationOptions();
					return;
				}
				if (matches.length === 1) {
					const only = matches[0];
					locationField.dataset.resolvedLocation = only.label;
					showLocationStatus(`Matched: ${only.label}`);
					hideLocationOptions();
					return;
				}
				const exact = matches.find((item) => item.label.toLowerCase() === query.toLowerCase());
				if (exact) {
					locationField.dataset.resolvedLocation = exact.label;
					showLocationStatus(`Matched: ${exact.label}`);
					hideLocationOptions();
					return;
				}
				locationField.dataset.resolvedLocation = "";
				showLocationStatus(`Select a location (${matches.length} matches).`);
				renderLocationOptions(locationField);
			} catch {
				if (lookupId !== locationLookupSeq) return;
				showLocationStatus("Location lookup failed. You can still enter it manually.", true);
				hideLocationOptions();
			}
		};

		if (options.immediate) {
			void execute();
		} else {
			locationLookupTimer = window.setTimeout(() => {
				void execute();
			}, 450);
		}
	}

