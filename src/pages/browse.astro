	.book-card {
		border: 1px solid #d7d7d7;
		border-radius: 12px;
		background: #fff;
		padding: 0.65rem;
		display: grid;
		grid-template-columns: 56px auto;
		gap: 0.65rem;
	}

	.cover-wrap {
		width: 56px;
		height: 84px;
	}

	.cover {
		width: 56px;
		height: 84px;
		object-fit: cover;
		border-radius: 6px;
		background: #f1f1f1;
	}

	.cover-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		color: #8a8a8a;
		border: 1px solid #d7d7d7;
	}

	.card-body h3 {
		margin: 0;
		font-size: 1rem;
	}

	.meta {
		margin: 0.2rem 0;
		font-size: 0.87rem;
		color: #4d4d4d;
	}

	.description {
		margin: 0.25rem 0 0;
		font-size: 0.85rem;
		color: #575757;
	}

	.shelf-dropdown {
		position: relative;
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		margin-top: 0.5rem;
