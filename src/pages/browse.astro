		source: "openlibrary",
		subjectKey: "fantasy",
		minPublishedDate: sixMonthsAgoIso
	},
	{
		id: "mystery-thriller",
		title: "Mystery & Thriller",
		subtitle: "Popular mystery and thriller picks from Open Library in the last 6 months.",
		source: "openlibrary",
		subjectKey: "mystery_and_detective_stories",
		minPublishedDate: sixMonthsAgoIso
	},
	{
		id: "romance",
		title: "Romance",
		subtitle: "Popular romance picks from Open Library in the last 6 months.",
		source: "openlibrary",
		subjectKey: "romance",
		minPublishedDate: sixMonthsAgoIso
	},
	{
		id: "science-fiction",
		title: "Science Fiction",
		subtitle: "Popular science fiction picks from Open Library in the last 6 months.",
		source: "openlibrary",
		subjectKey: "science_fiction",
		minPublishedDate: sixMonthsAgoIso
	},
	{
		id: "childrens",
		title: "Children's",
		subtitle: "Popular children's books from Open Library in the last 6 months.",
		source: "openlibrary",
		subjectKey: "children",
		subjectQuery: "children's books",
		minPublishedDate: sixMonthsAgoIso
	},
	{
		id: "biographies",
		title: "Biographies",
		subtitle: "Popular biographies from Open Library in the last 6 months.",
		source: "openlibrary",
		subjectKey: "biography",
		subjectQuery: "biography",
		minPublishedDate: sixMonthsAgoIso
	},
