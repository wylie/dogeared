---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

type BrowseBook = {
	id: string;
	title: string;
	authors: string[];
	thumbnail: string;
	publishedDate: string;
	description: string;
	pageCount: number;
	format: string;
	language: string;
};

type BrowseSection = {
	id: string;
	title: string;
	subtitle: string;
	source: "google" | "nyt" | "openlibrary";
	listDate: string;
	listDateNote: string;
	queries?: string[];
	listName?: string;
	subjectKey?: string;
	subjectQuery?: string;
	orderBy?: "relevance" | "newest";
	minYear?: number;
	minPublishedDate?: string;
	books: BrowseBook[];
};

function toHttps(value: unknown) {
	const input = String(value || "").trim();
	if (!input) return "";
	if (input.startsWith("http://")) return `https://${input.slice(7)}`;
	return input;
}

function trimDescription(value: unknown, max = 180) {
	const text = String(value || "").replace(/\s+/g, " ").trim();
	if (!text) return "";
	if (text.length <= max) return text;
	return `${text.slice(0, max).trim()}...`;
}

function formatDate(value: string) {
	const text = String(value || "").trim();
	if (!text) return "";
	const parsed = new Date(text);
	if (!Number.isFinite(parsed.getTime())) return text;
	return parsed.toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric"
	});
}

function formatPublishedLabel(value: string) {
	const text = String(value || "").trim();
	if (!text) return "";
	if (/^\d{4}$/.test(text)) return text;
	if (/^\d{4}-\d{2}$/.test(text)) {
		const parsed = new Date(`${text}-01`);
		if (!Number.isFinite(parsed.getTime())) return text;
		return parsed.toLocaleDateString("en-US", {
			month: "long",
			year: "numeric"
		});
	}
	const parsed = new Date(text);
	if (!Number.isFinite(parsed.getTime())) return text;
	return parsed.toLocaleDateString("en-US", {
		month: "long",
		day: "numeric",
		year: "numeric"
	});
}

function openLibraryCoverUrl(coverId: unknown) {
	const id = Number(coverId || 0);
	if (!id || !Number.isFinite(id)) return "";
	return `https://covers.openlibrary.org/b/id/${id}-M.jpg`;
}

async function fetchShelf(query: string, options: { orderBy?: "relevance" | "newest"; maxResults?: number; apiKey: string }) {
	const endpoint = new URL("https://www.googleapis.com/books/v1/volumes");
	endpoint.searchParams.set("q", query);
	endpoint.searchParams.set("printType", "books");
	endpoint.searchParams.set("langRestrict", "en");
	endpoint.searchParams.set("maxResults", String(options.maxResults || 12));
	endpoint.searchParams.set("orderBy", options.orderBy || "relevance");
	endpoint.searchParams.set("key", options.apiKey);

	const response = await fetch(endpoint.toString(), {
		headers: { Accept: "application/json" }
	});
	if (!response.ok) return [];

	const data = await response.json();
	const items = Array.isArray(data?.items) ? data.items : [];
	const dedupe = new Set<string>();
	const books: BrowseBook[] = [];

	for (const item of items) {
		const info = item?.volumeInfo || {};
		const title = String(info?.title || "").trim();
		if (!title) continue;
		const authors = Array.isArray(info?.authors) ? info.authors.map((a: unknown) => String(a || "").trim()).filter(Boolean) : [];
		const key = `${title.toLowerCase()}|${(authors[0] || "").toLowerCase()}`;
		if (dedupe.has(key)) continue;
		dedupe.add(key);
		books.push({
			id: String(item?.id || `${title}-${authors[0] || "unknown"}`),
			title,
			authors,
			thumbnail: toHttps(info?.imageLinks?.thumbnail || info?.imageLinks?.smallThumbnail || ""),
			publishedDate: String(info?.publishedDate || "").trim(),
			description: trimDescription(info?.description),
			pageCount: Math.max(0, Number(info?.pageCount || 0) || 0),
			format: "Book",
			language: String(info?.language || "").trim().toUpperCase()
		});
	}

	return books;
}

async function fetchOpenLibrarySubject(
	subjectKey: string,
	options: { maxResults?: number; minPublishedDate?: string; subjectQuery?: string }
) {
	const maxResults = options.maxResults || 12;
	const candidateLimit = maxResults * 8;
	const minTs = options.minPublishedDate ? publishedDateToTimestamp(options.minPublishedDate) : 0;
	const dedupe = new Set<string>();
	const recentBooks: BrowseBook[] = [];
	const subjectSearch = String(options.subjectQuery || subjectKey).trim().replace(/_/g, " ");

	// First pass: try Open Library search sorted by new to get fresh titles in this genre.
	const searchEndpoint = new URL("https://openlibrary.org/search.json");
	searchEndpoint.searchParams.set("subject", subjectSearch);
	searchEndpoint.searchParams.set("sort", "new");
	searchEndpoint.searchParams.set("language", "eng");
	searchEndpoint.searchParams.set("limit", String(candidateLimit));

	try {
		const searchResponse = await fetch(searchEndpoint.toString(), {
			headers: { Accept: "application/json" }
		});
		if (searchResponse.ok) {
			const searchData = await searchResponse.json();
			const docs = Array.isArray(searchData?.docs) ? searchData.docs : [];
			for (const doc of docs) {
				const title = String(doc?.title || "").trim();
				if (!title) continue;
				const author = Array.isArray(doc?.author_name) ? String(doc.author_name[0] || "").trim() : "";
				const authors = author ? [author] : [];
				const key = `${title.toLowerCase()}|${author.toLowerCase()}`;
				if (dedupe.has(key)) continue;
				dedupe.add(key);

				const pubYear = Array.isArray(doc?.publish_year)
					? Math.max(...doc.publish_year.filter((year: unknown) => Number.isFinite(Number(year))).map((year: unknown) => Number(year)))
					: Number(doc?.first_publish_year || 0);
				const publishedDate = Number.isFinite(pubYear) && pubYear > 0 ? String(pubYear) : "";
				const publishedTs = publishedDateToTimestamp(publishedDate);
				if (minTs > 0 && (!publishedTs || publishedTs < minTs)) continue;
				const rawSynopsis = Array.isArray(doc?.first_sentence)
					? String(doc.first_sentence[0] || "").trim()
					: typeof doc?.first_sentence === "string"
						? doc.first_sentence.trim()
						: typeof doc?.subtitle === "string"
							? doc.subtitle.trim()
							: "";

				recentBooks.push({
					id: String(doc?.key || key),
					title,
					authors,
					thumbnail: openLibraryCoverUrl(doc?.cover_i),
					publishedDate,
					description: trimDescription(rawSynopsis),
					pageCount: 0,
					format: "Book",
					language: "EN"
				});

				if (recentBooks.length >= maxResults) break;
			}
		}
	} catch {
		// Fall through to subject endpoint below.
	}

	if (recentBooks.length >= maxResults) {
		return recentBooks.slice(0, maxResults);
	}

	// Fallback: subject list (popular by genre), then apply recency if possible.
	const endpoint = new URL(`https://openlibrary.org/subjects/${subjectKey}.json`);
	endpoint.searchParams.set("limit", String(candidateLimit));
	endpoint.searchParams.set("details", "true");

	const response = await fetch(endpoint.toString(), {
		headers: { Accept: "application/json" }
	});
	if (!response.ok) return recentBooks.slice(0, maxResults);

	const data = await response.json();
	const works = Array.isArray(data?.works) ? data.works : [];
	const books: BrowseBook[] = [...recentBooks];

	for (const work of works) {
		const title = String(work?.title || "").trim();
		if (!title) continue;
		const authors = Array.isArray(work?.authors)
			? work.authors.map((author: { name?: unknown }) => String(author?.name || "").trim()).filter(Boolean)
			: [];
		const key = `${title.toLowerCase()}|${(authors[0] || "").toLowerCase()}`;
		if (dedupe.has(key)) continue;
		dedupe.add(key);

		const firstSentence = Array.isArray(work?.first_sentence)
			? String(work.first_sentence[0] || "").trim()
			: typeof work?.first_sentence === "string"
				? work.first_sentence.trim()
				: "";

		books.push({
			id: String(work?.key || key),
			title,
			authors,
			thumbnail: openLibraryCoverUrl(work?.cover_id),
			publishedDate: String(work?.first_publish_year || "").trim(),
			description: trimDescription(firstSentence),
			pageCount: 0,
			format: "Book",
			language: "EN"
		});
	}

	let filtered = books;
	if (options.minPublishedDate) {
		if (minTs > 0) {
			filtered = books.filter((book) => {
				const publishedTs = publishedDateToTimestamp(book.publishedDate);
				return publishedTs >= minTs;
			});
		}
	}

	// If strict recent filter is empty, show most recent available instead of blank shelves.
	const finalBooks = filtered.length > 0 ? filtered : books;
	finalBooks.sort((a, b) => dateScore(b.publishedDate) - dateScore(a.publishedDate));
	return finalBooks.slice(0, maxResults);
}

async function fetchNytList(listName: string, options: { apiKey: string; maxResults?: number }) {
	const endpoint = new URL(`https://api.nytimes.com/svc/books/v3/lists/current/${listName}.json`);
	endpoint.searchParams.set("api-key", options.apiKey);

	const response = await fetch(endpoint.toString(), {
		headers: { Accept: "application/json" }
	});
	if (!response.ok) {
		return {
			books: [] as BrowseBook[],
			listDate: "",
			listDateNote: ""
		};
	}

	const data = await response.json();
	const results = data?.results || {};
	const defaultPublishedDate = String(results?.published_date || results?.bestsellers_date || "").trim();
	const books = Array.isArray(results?.books) ? results.books : [];
	const dedupe = new Set<string>();
	const mapped: BrowseBook[] = [];

	for (const book of books) {
		const title = String(book?.title || "").trim();
		if (!title) continue;
		const author = String(book?.author || "").trim();
		const key = `${title.toLowerCase()}|${author.toLowerCase()}`;
		if (dedupe.has(key)) continue;
		dedupe.add(key);
		mapped.push({
			id: String(book?.primary_isbn13 || book?.primary_isbn10 || key),
			title,
			authors: author ? [author] : [],
			thumbnail: toHttps(book?.book_image || ""),
			publishedDate: String(book?.published_date || defaultPublishedDate || "").trim(),
			description: trimDescription(book?.description),
			pageCount: 0,
			format: "Book",
			language: "EN"
		});
	}

	const listDate = formatDate(String(results?.published_date || results?.bestsellers_date || "").trim());
	const updateMode = String(results?.updated || "").trim().toLowerCase();
	const updateLabel = updateMode ? `${updateMode.slice(0, 1).toUpperCase()}${updateMode.slice(1)} update` : "";

	return {
		books: mapped.slice(0, options.maxResults || 12),
		listDate,
		listDateNote: updateLabel
	};
}

function extractYear(value: string) {
	const match = String(value || "").match(/\d{4}/);
	return match ? Number(match[0]) : 0;
}

function publishedDateToTimestamp(value: string) {
	const text = String(value || "").trim();
	if (!text) return 0;
	if (/^\d{4}$/.test(text)) {
		const parsed = new Date(`${text}-01-01`).getTime();
		return Number.isFinite(parsed) ? parsed : 0;
	}
	if (/^\d{4}-\d{2}$/.test(text)) {
		const parsed = new Date(`${text}-01`).getTime();
		return Number.isFinite(parsed) ? parsed : 0;
	}
	const parsed = new Date(text).getTime();
	if (Number.isFinite(parsed)) return parsed;
	return 0;
}

function dateScore(value: string) {
	const text = String(value || "").trim();
	if (!text) return 0;
	const safe = /^\d{4}$/.test(text) ? `${text}-01-01` : text;
	const ts = new Date(safe).getTime();
	if (Number.isFinite(ts) && ts > 0) return ts;
	return extractYear(text) * 10000;
}

async function fetchShelfFromQueries(
	queries: string[],
	options: { orderBy?: "relevance" | "newest"; maxResults?: number; apiKey: string; minYear?: number; minPublishedDate?: string }
) {
	const all = await Promise.all(
		queries.map((query) => fetchShelf(query, {
			orderBy: options.orderBy,
			maxResults: options.maxResults,
			apiKey: options.apiKey
		}))
	);

	const dedupe = new Set<string>();
	let merged = all.flat().filter((book) => {
		const key = `${book.title.toLowerCase()}|${(book.authors[0] || "").toLowerCase()}`;
		if (dedupe.has(key)) return false;
		dedupe.add(key);
		return true;
	});

	if (options.minYear) {
		const strict = merged.filter((book) => extractYear(book.publishedDate) >= options.minYear!);
		if (strict.length > 0) {
			merged = strict;
		} else {
			const relaxed = merged.filter((book) => extractYear(book.publishedDate) >= (options.minYear! - 3));
			merged = relaxed.length > 0 ? relaxed : merged;
		}
	}

	if (options.minPublishedDate) {
		const minTs = publishedDateToTimestamp(options.minPublishedDate);
		if (minTs > 0) {
			merged = merged.filter((book) => {
				const publishedTs = publishedDateToTimestamp(book.publishedDate);
				return publishedTs >= minTs;
			});
		}
	}

	merged.sort((a, b) => dateScore(b.publishedDate) - dateScore(a.publishedDate));
	return merged.slice(0, options.maxResults || 12);
}

const googleApiKey = String(import.meta.env.GOOGLE_BOOKS_API_KEY || "").trim();
const nytApiKey = String(import.meta.env.NYT_BOOKS_API_KEY || "").trim();
const sixMonthsAgoIso = new Date(
	new Date().getFullYear(),
	new Date().getMonth() - 6,
	new Date().getDate()
).toISOString().slice(0, 10);
const sectionsConfig: Omit<BrowseSection, "books" | "listDate" | "listDateNote">[] = [
	{
		id: "nyt-fiction",
		title: "NYT Best Sellers: Fiction",
		subtitle: "Current New York Times hardcover fiction best sellers.",
		source: "nyt",
		listName: "hardcover-fiction"
	},
	{
		id: "nyt-nonfiction",
		title: "NYT Best Sellers: Nonfiction",
		subtitle: "Current New York Times hardcover nonfiction best sellers.",
		source: "nyt",
		listName: "hardcover-nonfiction"
	},
	{
		id: "nyt-audio-fiction",
		title: "NYT Audio Fiction",
		subtitle: "Current New York Times audio fiction best sellers.",
		source: "nyt",
		listName: "audio-fiction"
	},
	{
		id: "nyt-audio-nonfiction",
		title: "NYT Audio Nonfiction",
		subtitle: "Current New York Times audio nonfiction best sellers.",
		source: "nyt",
		listName: "audio-nonfiction"
	},
	{
