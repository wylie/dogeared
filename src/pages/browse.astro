		source: "nyt",
		listName: "combined-print-and-e-book-fiction"
	}
];

let sections: BrowseSection[] = [];
let errorMessage = "";

try {
	const results = await Promise.all(
		sectionsConfig.map(async (section) => {
			if (section.source === "nyt") {
				if (!nytApiKey || !section.listName) {
					return { books: [] as BrowseBook[], listDate: "", listDateNote: "" };
				}
				return fetchNytList(section.listName, {
					apiKey: nytApiKey,
					maxResults: 12
				});
			}
			if (section.source === "openlibrary") {
				if (!section.subjectKey) {
					return { books: [] as BrowseBook[], listDate: "", listDateNote: "" };
				}
				const books = await fetchOpenLibrarySubject(section.subjectKey, {
					maxResults: 12,
					minPublishedDate: section.minPublishedDate,
					subjectQuery: section.subjectQuery
				});
				return { books, listDate: "", listDateNote: "" };
			}
			if (!googleApiKey || !section.queries || section.queries.length === 0) {
				return { books: [] as BrowseBook[], listDate: "", listDateNote: "" };
			}
			const books = await fetchShelfFromQueries(section.queries, {
				orderBy: section.orderBy,
				minYear: section.minYear,
				minPublishedDate: section.minPublishedDate,
				maxResults: 12,
				apiKey: googleApiKey
			});
			return { books, listDate: "", listDateNote: "" };
		})
	);

	sections = sectionsConfig.map((section, index) => ({
		...section,
		books: results[index]?.books || [],
		listDate: results[index]?.listDate || "",
		listDateNote: results[index]?.listDateNote || ""
	}))
		// Hide sparse shelves to keep Browse focused.
		.filter((section) => section.books.length >= 4);
} catch (error) {
	errorMessage = error instanceof Error ? error.message : "Failed to load browse shelves.";
}
---

<Layout title="Browse" sectionLinks={sections.map((section) => ({ id: section.id, label: section.title }))}>
	<div slot="right" class="browse-page">
		<h1>Browse</h1>
		<p class="subhead">Discover books with NYT best sellers and Open Library genre shelves.</p>

		{errorMessage && <p class="error">Browse unavailable: {errorMessage}</p>}

		{!errorMessage && sections.length > 0 && (
			<>
				{sections.map((section) => (
					<section id={section.id} class="browse-section">
						<div class="section-head">
							<h2>{section.title}</h2>
							<p>{section.subtitle}</p>
							{section.listDate && (
								<p class="list-date">
									List date: {section.listDate}
									{section.listDateNote ? ` • ${section.listDateNote}` : ""}
								</p>
							)}
						</div>
						{section.books.length === 0 && <p class="empty">No books found for this shelf yet.</p>}
						{section.books.length > 0 && (
							<ul class="book-grid">
								{section.books.map((book) => (
									<li class="book-card">
										<div class="cover-wrap">
											{book.thumbnail
												? <img class="cover" src={book.thumbnail} alt={`${book.title} cover`} loading="lazy" />
												: <div class="cover cover-placeholder"><span class="material-icons" aria-hidden="true">menu_book</span></div>}
										</div>
										<div class="card-body">
											<h3>{book.title}</h3>
											<p class="meta">{book.authors.length > 0 ? book.authors.join(", ") : "Unknown author"}</p>
											{book.publishedDate && <p class="meta">Published: {formatPublishedLabel(book.publishedDate)}</p>}
											{book.description && <p class="description">{book.description}</p>}
											{!book.description && section.source !== "nyt" && <p class="description">Synopsis unavailable for this edition.</p>}
											<div
												class="shelf-dropdown"
												data-title={book.title}
												data-author={book.authors[0] ?? ""}
												data-pages={String(book.pageCount ?? 0)}
												data-cover={book.thumbnail}
												data-format={book.format}
												data-language={book.language}
											>
												<button type="button" class="shelf-trigger" data-action="toggle-shelf" aria-expanded="false">
													<span class="material-icons shelf-check" aria-hidden="true">check</span>
													<span class="shelf-label">Want to Read</span>
													<span class="material-icons shelf-icon" aria-hidden="true">arrow_drop_down</span>
												</button>
												<div class="shelf-menu" hidden>
													<button type="button" class="shelf-option" data-action="set-shelf" data-status="want_to_read">Want to Read</button>
													<button type="button" class="shelf-option" data-action="set-shelf" data-status="reading">Currently Reading</button>
													<button type="button" class="shelf-option" data-action="set-shelf" data-status="finished">Read</button>
												</div>
												<p class="shelf-feedback" hidden></p>
											</div>
										</div>
									</li>
								))}
							</ul>
						)}
					</section>
				))}
			</>
		)}
	</div>
</Layout>

<style>
	.browse-page {
		max-width: 920px;
	}

	.browse-page h1 {
		margin: 0;
	}

	.subhead {
		margin: 0.5rem 0 1rem;
		color: #4d4d4d;
	}

	.error {
		background: #fff1f2;
		color: #9f1239;
		border: 1px solid #fecdd3;
		padding: 0.7rem 0.8rem;
		border-radius: 10px;
	}

	.browse-section {
		margin-top: 1.35rem;
	}

	.section-head {
		position: sticky;
		top: 0;
		padding-bottom: .5rem;
		background-color: #efefef;
		z-index: 100;
	}
	.section-head h2 {
		margin: 0;
	}

	.section-head p {
		margin: 0.25rem 0 0.7rem;
		color: #4d4d4d;
		font-size: 0.92rem;
	}

	.list-date {
		margin-top: -0.35rem;
		color: #5f5f5f;
		font-size: 0.84rem;
