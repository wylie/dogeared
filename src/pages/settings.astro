			localStorage.removeItem("dogeared:myreads");
			localStorage.removeItem("dogeared:profile-info");
			localStorage.removeItem("dogeared:updates");
			showAccountFeedback("Account deleted.");
			await loadAuthState();
		} catch {
			showAccountFeedback("Failed to delete account.", true);
		}
	});

	for (const button of copyButtons) {
		button.addEventListener("click", () => {
			const targetId = String(button.getAttribute("data-copy-target") || "").trim();
			if (!targetId) return;
			void copyApiValue(targetId);
		});
	}

	downloadDataButton?.addEventListener("click", async () => {
		const button = downloadDataButton instanceof HTMLButtonElement ? downloadDataButton : null;
		showExportFeedback("Preparing your data export...");
		if (button) button.disabled = true;
		try {
			const response = await fetch("/api/account/export");
			const data = await response.json().catch(() => ({}));
			if (!response.ok) {
				showExportFeedback(String(data?.error || "Failed to generate export."), true);
				return;
			}
			const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json;charset=utf-8" });
			const url = URL.createObjectURL(blob);
			const datePart = new Date().toISOString().slice(0, 10);
			const link = document.createElement("a");
			link.href = url;
			link.download = `dogeared-export-${datePart}.json`;
			document.body.appendChild(link);
			link.click();
			link.remove();
			URL.revokeObjectURL(url);
			showExportFeedback("Export downloaded.");
		} catch {
			showExportFeedback("Failed to generate export.", true);
		} finally {
			if (button) button.disabled = false;
		}
	});

	clearShelfButton?.addEventListener("click", async () => {
		const confirmed = window.confirm("Delete all shelf entries? This keeps your account but removes all saved books.");
		if (!confirmed) return;
		showExportFeedback("Deleting all shelf entries...");
		const button = clearShelfButton instanceof HTMLButtonElement ? clearShelfButton : null;
		if (button) button.disabled = true;
		try {
			const ok = await clearShelfOnServer();
			if (!ok) {
				showExportFeedback("Failed to delete shelf entries.", true);
				return;
			}
			localStorage.setItem(STORAGE_KEY, "[]");
			localStorage.setItem(UPDATES_KEY, "[]");
			showExportFeedback("All shelf entries deleted.");
		} catch {
			showExportFeedback("Failed to delete shelf entries.", true);
		} finally {
			if (button) button.disabled = false;
		}
	});

	savePreferencesButton?.addEventListener("click", async () => {
		const button = savePreferencesButton instanceof HTMLButtonElement ? savePreferencesButton : null;
		showPreferencesFeedback("Saving preferences...");
		if (button) button.disabled = true;
		try {
			await savePreferences();
			showPreferencesFeedback("Preferences saved.");
		} catch (error) {
			showPreferencesFeedback(error instanceof Error ? error.message : "Failed to save preferences.", true);
		} finally {
			if (button) button.disabled = false;
		}
	});

	async function loadSecurityView() {
		try {
			const [sessionsRes, activityRes] = await Promise.all([
				fetch("/api/account/sessions"),
				fetch(`/api/activity/recent?userKey=${encodeURIComponent(getUserKey())}&limit=8`)
			]);
			if (sessionsRes.ok && sessionList instanceof HTMLElement) {
				const data = await sessionsRes.json().catch(() => ({}));
				const sessions = Array.isArray(data?.sessions) ? data.sessions : [];
				if (!sessions.length) {
					sessionList.innerHTML = "<p><strong>Active sessions:</strong> none</p>";
				} else {
					sessionList.innerHTML = `
						<p><strong>Active sessions:</strong></p>
						<ul>${sessions.map((item) => `<li>${item.label}${item.isCurrent ? " (current)" : ""} · expires ${new Date(item.expiresAt).toLocaleString()}</li>`).join("")}</ul>
					`;
				}
			}
			if (activityRes.ok && recentActivityList instanceof HTMLElement) {
				const data = await activityRes.json().catch(() => ({}));
				const updates = Array.isArray(data?.updates) ? data.updates : [];
				if (!updates.length) {
					recentActivityList.innerHTML = "<p><strong>Recent activity:</strong> none</p>";
				} else {
					recentActivityList.innerHTML = `
						<p><strong>Recent activity:</strong></p>
						<ul>${updates.map((item) => `<li>${item.status} · ${item.title} · ${new Date(item.timestamp).toLocaleString()}</li>`).join("")}</ul>
					`;
				}
			}
			showSecurityFeedback("");
		} catch {
			showSecurityFeedback("Failed to load security details.", true);
		}
	}

	refreshSecurityButton?.addEventListener("click", () => {
		void loadSecurityView();
	});

	revokeSessionsButton?.addEventListener("click", async () => {
		showSecurityFeedback("Revoking other sessions...");
		try {
			const response = await fetch("/api/account/sessions", { method: "POST" });
			if (!response.ok) {
				const data = await response.json().catch(() => ({}));
				showSecurityFeedback(String(data?.error || "Failed to revoke sessions."), true);
				return;
			}
			showSecurityFeedback("Other sessions revoked.");
			await loadSecurityView();
		} catch {
			showSecurityFeedback("Failed to revoke sessions.", true);
		}
	});

	populateApiEndpoints();
	void loadAuthState();
	void loadPreferences();
	void loadSecurityView();
</script>
