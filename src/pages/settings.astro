			if (accountDangerZone instanceof HTMLElement) accountDangerZone.hidden = true;
			if (magicLinkForm instanceof HTMLFormElement) magicLinkForm.hidden = false;
			if (downloadDataButton instanceof HTMLButtonElement) downloadDataButton.disabled = true;
			if (clearShelfButton instanceof HTMLButtonElement) clearShelfButton.disabled = true;
			if (savePreferencesButton instanceof HTMLButtonElement) savePreferencesButton.disabled = true;
			if (revokeSessionsButton instanceof HTMLButtonElement) revokeSessionsButton.disabled = true;
			if (refreshSecurityButton instanceof HTMLButtonElement) refreshSecurityButton.disabled = true;
