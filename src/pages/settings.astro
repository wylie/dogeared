---
import Layout from '../layouts/Layout.astro';

const sectionLinks = [
	{ id: "goodreads-import", label: "Import Goodreads" },
	{ id: "import-controls", label: "Import Controls" },
	{ id: "account-settings", label: "Account" },
	{ id: "privacy-settings", label: "Privacy" },
	{ id: "reading-defaults", label: "Reading Defaults" },
	{ id: "personalization-settings", label: "Personalization" },
	{ id: "security-settings", label: "Security" },
	{ id: "api-settings", label: "API" },
	{ id: "data-export", label: "Data Export" }
];
---

<Layout title="Settings" sectionLinks={sectionLinks}>
	<div slot="right" class="settings-page">
		<h1>Settings</h1>
		<p class="subhead">Manage imports and account preferences.</p>

		<section class="settings-section" id="goodreads-import" aria-labelledby="goodreads-import-title">
			<h2 id="goodreads-import-title">Import Goodreads Data</h2>
			<p class="section-copy">
				Upload your Goodreads library export CSV to import shelves into Dogeared.
			</p>
			<ol class="steps">
				<li>In Goodreads, go to My Books and export your library as CSV.</li>
				<li>Upload that CSV file here.</li>
				<li>Review the import summary and open your <a href="/profile">Profile</a>.</li>
			</ol>

			<form id="goodreads-import-form" class="import-form">
				<label for="goodreads-csv">Goodreads CSV</label>
				<input id="goodreads-csv" name="goodreadsCsv" type="file" accept=".csv,text/csv" required />
				<button type="submit">Import Goodreads CSV</button>
			</form>

			<p id="import-feedback" class="feedback" hidden></p>
			<div id="import-summary" class="summary" hidden></div>
		</section>

		<section class="settings-section" id="import-controls" aria-labelledby="import-controls-title">
			<h2 id="import-controls-title">Import Controls</h2>
			<p class="section-copy">
				Preview incoming rows and choose whether imports merge with existing shelf entries or replace them.
			</p>
			<div class="danger-form">
				<label for="import-mode">Default import mode</label>
				<select id="import-mode">
					<option value="merge">Merge with existing shelf</option>
					<option value="replace">Replace existing shelf</option>
				</select>
				<label class="checkbox-row">
					<input type="checkbox" id="import-dry-run-first" checked />
					<span>Show dry-run preview before writing data</span>
				</label>
				<button type="button" id="preview-import-button" class="secondary">Preview Current CSV</button>
			</div>
			<p id="import-controls-feedback" class="feedback" hidden></p>
		</section>

		<section class="settings-section" id="account-settings" aria-labelledby="account-settings-title">
			<h2 id="account-settings-title">Account</h2>
			<p class="section-copy">
				Sign in with a magic link delivered through Brevo, sign out, or permanently delete your account.
			</p>

			<div class="account-blocks">
				<div class="account-panel">
					<h3>Authentication</h3>
					<div id="account-signed-in-state" hidden>
						<p class="account-meta">Signed in as <strong id="account-email"></strong></p>
						<div class="account-actions">
							<button type="button" id="logout-button" class="secondary">Log Out</button>
						</div>
					</div>
					<form id="magic-link-form" class="import-form" hidden>
						<label for="magic-email">Email</label>
						<input id="magic-email" type="email" autocomplete="email" required placeholder="you@example.com" />
						<button type="submit">Send Magic Link</button>
					</form>
				</div>

				<div id="account-danger-zone" class="account-panel account-panel-danger" hidden>
					<h3>Danger Zone</h3>
					<p class="danger-copy">
						Delete account permanently removes your account and synced shelf data.
					</p>
					<form id="delete-account-form" class="danger-form">
						<label for="delete-confirm">Type <code>DELETE</code> to confirm</label>
						<input id="delete-confirm" type="text" autocomplete="off" />
						<button type="submit" class="danger">Delete Account</button>
					</form>
				</div>
			</div>

			<p id="account-feedback" class="feedback" hidden></p>
		</section>

		<section class="settings-section" id="privacy-settings" aria-labelledby="privacy-settings-title">
			<h2 id="privacy-settings-title">Privacy</h2>
			<p class="section-copy">Control profile visibility and what appears to other readers.</p>
			<div class="danger-form">
				<label for="profile-visibility">Profile visibility</label>
				<select id="profile-visibility">
					<option value="public">Public profile</option>
					<option value="private">Private profile</option>
				</select>
				<label class="checkbox-row">
					<input type="checkbox" id="share-location" checked />
					<span>Show my location on profile and metrics</span>
				</label>
				<label class="checkbox-row">
					<input type="checkbox" id="share-activity" checked />
					<span>Show my shelf activity in activity feed</span>
				</label>
			</div>
		</section>

		<section class="settings-section" id="reading-defaults" aria-labelledby="reading-defaults-title">
			<h2 id="reading-defaults-title">Reading Defaults</h2>
			<p class="section-copy">Choose default shelf behavior and list sorting.</p>
			<div class="danger-form">
				<label for="default-shelf">Default shelf when adding books</label>
				<select id="default-shelf">
					<option value="want_to_read">Want to Read</option>
					<option value="reading">Currently Reading</option>
					<option value="finished">Read</option>
				</select>
				<label for="home-sort">Default home/profile sort</label>
				<select id="home-sort">
					<option value="relevance">Relevance</option>
					<option value="recent">Most Recent</option>
					<option value="rating">Highest Rated</option>
				</select>
			</div>
		</section>

		<section class="settings-section" id="personalization-settings" aria-labelledby="personalization-settings-title">
			<h2 id="personalization-settings-title">Personalization</h2>
			<p class="section-copy">Set preferences that shape search, ranking, and recommendations.</p>
			<div class="danger-form">
				<label for="favorite-genres-input">Favorite genres (comma separated)</label>
				<input id="favorite-genres-input" type="text" placeholder="Fantasy, Science Fiction" />
				<label for="excluded-genres-input">Excluded genres (comma separated)</label>
				<input id="excluded-genres-input" type="text" placeholder="Horror" />
			</div>
		</section>

		<section class="settings-section" id="api-settings" aria-labelledby="api-settings-title">
			<h2 id="api-settings-title">API</h2>
			<p class="section-copy">
				Dogeared now stores shelved books in its own catalog. Use these routes to read from the Dogeared API instead of relying on third-party APIs for saved data.
			</p>

			<div class="api-grid">
				<div class="api-card">
					<h3>My Shelf</h3>
					<p class="api-copy">Returns the saved books currently synced to your Dogeared shelf.</p>
					<label for="api-shelf-url">Endpoint</label>
					<div class="api-url-row">
						<input id="api-shelf-url" class="api-url" type="text" readonly value="" />
						<button type="button" class="secondary copy-button" data-copy-target="api-shelf-url">Copy</button>
					</div>
				</div>

				<div class="api-card">
					<h3>Catalog Search</h3>
					<p class="api-copy">Searches books through Dogeared's server-side search route.</p>
					<label for="api-search-url">Endpoint</label>
					<div class="api-url-row">
						<input id="api-search-url" class="api-url" type="text" readonly value="" />
						<button type="button" class="secondary copy-button" data-copy-target="api-search-url">Copy</button>
					</div>
				</div>

				<div class="api-card">
					<h3>Top Books By Genre</h3>
					<p class="api-copy">Returns books ranked from real Dogeared shelf activity.</p>
					<label for="api-top-url">Endpoint</label>
					<div class="api-url-row">
						<input id="api-top-url" class="api-url" type="text" readonly value="" />
						<button type="button" class="secondary copy-button" data-copy-target="api-top-url">Copy</button>
					</div>
				</div>
			</div>

			<p class="api-note">
				Search still begins with Google Books, but once a book is shelved or imported it can be served back from Dogeared's own database.
			</p>
			<p id="api-feedback" class="feedback" hidden></p>
		</section>

		<section class="settings-section" id="data-export" aria-labelledby="data-export-title">
			<h2 id="data-export-title">Data Export</h2>
			<p class="section-copy">
				Download a JSON export of your account profile and shelved books.
			</p>
			<div class="account-actions">
				<button type="button" id="download-data-button" disabled>Download My Data (JSON)</button>
			</div>
			<div class="danger-form">
				<label for="preferred-export-format">Preferred export format</label>
				<select id="preferred-export-format">
					<option value="json">JSON</option>
					<option value="csv" disabled>CSV (Coming Soon)</option>
				</select>
			</div>
			<hr />
			<p class="danger-copy">Delete all shelf entries while keeping your account.</p>
			<div class="account-actions">
				<button type="button" id="clear-shelf-button" class="danger">Delete All Shelf Entries</button>
			</div>
			<p id="export-feedback" class="feedback" hidden></p>
		</section>

		<section class="settings-section" id="security-settings" aria-labelledby="security-settings-title">
			<h2 id="security-settings-title">Security</h2>
			<p class="section-copy">Review active sessions and recent activity.</p>
			<div class="account-actions">
				<button type="button" id="refresh-security-button" class="secondary">Refresh</button>
				<button type="button" id="revoke-sessions-button" class="secondary">Revoke Other Sessions</button>
			</div>
			<div id="session-list" class="summary"></div>
			<div id="recent-activity-list" class="summary"></div>
			<p id="security-feedback" class="feedback" hidden></p>
		</section>

		<div class="account-actions">
			<button type="button" id="save-preferences-button">Save Preferences</button>
		</div>
		<p id="preferences-feedback" class="feedback" hidden></p>
	</div>
</Layout>

<style>
	.settings-page {
		max-width: 860px;
	}

	h1 {
		margin: 0;
	}

	.subhead {
		margin: 0.5rem 0 1.25rem;
		color: #444;
	}

	.settings-section {
		border: 1px solid #d8d8d8;
		border-radius: 12px;
		padding: 1rem;
		background: #fff;
		margin-top: 1rem;
	}

	.settings-section h2 {
		margin: 0;
	}

	.section-copy {
		margin: 0.5rem 0 0.8rem;
		color: #333;
	}

	.steps {
		margin: 0 0 1rem 1.1rem;
		padding: 0;
		display: grid;
		gap: 0.4rem;
	}

	.import-form {
		display: grid;
		gap: 0.55rem;
	}

	label {
		font-weight: 600;
	}

	input[type="file"] {
		font-size: 0.95rem;
	}

	input[type="text"],
	input[type="email"],
	select {
		width: 100%;
		max-width: 100%;
		box-sizing: border-box;
		border: 1px solid #d1d5db;
		border-radius: 8px;
		padding: 0.6rem 0.7rem;
		font: inherit;
		background: #fff;
	}

	.checkbox-row {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: 400;
	}

	.checkbox-row input[type="checkbox"] {
		width: 1rem;
		height: 1rem;
	}

	button {
		border: none;
		border-radius: 8px;
		padding: 0.6rem 0.9rem;
		font-size: 0.95rem;
		background: #111;
		color: #fff;
		cursor: pointer;
		justify-self: start;
	}

	.feedback {
		margin: 0.85rem 0 0;
		padding: 0.7rem 0.8rem;
		border-radius: 9px;
		background: #f3f4f6;
		color: #1f2937;
	}

	.feedback.error {
		background: #fef2f2;
		color: #991b1b;
	}

	.summary {
		margin-top: 0.8rem;
		padding: 0.85rem;
		border: 1px dashed #c8c8c8;
		border-radius: 10px;
		background: #fafafa;
	}

	.summary p {
		margin: 0.2rem 0;
	}

	.secondary {
		background: #efefef;
		color: #222;
	}

	.danger {
		background: #991b1b;
	}

	.account-meta {
		margin: 0 0 0.6rem;
	}

	.account-blocks {
		display: grid;
		gap: 1.1rem;
	}

	.account-panel {
		border: 1px solid #e5e7eb;
		border-radius: 10px;
		background: #fafafa;
		padding: 0.85rem;
	}

	.account-panel h3 {
		margin: 0 0 0.5rem;
		font-size: 1rem;
	}

	.account-panel-danger {
		border-color: #f1b4b4;
		background: #fff7f7;
	}

	.account-actions {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 0.8rem;
	}

	.danger-copy {
		color: #991b1b;
		margin: 0.8rem 0 0.35rem;
	}

	.danger-form {
		display: grid;
		gap: 0.45rem;
		max-width: 340px;
	}

	.api-grid {
		display: grid;
		gap: 0.85rem;
	}

	.api-card {
		border: 1px solid #e5e7eb;
		border-radius: 10px;
		padding: 0.85rem;
		background: #fafafa;
	}

	.api-card h3 {
		margin: 0 0 0.35rem;
		font-size: 1rem;
	}

	.api-copy {
		margin: 0 0 0.55rem;
		color: #4b5563;
	}

	.api-url-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.5rem;
		align-items: center;
	}

	.api-url {
		width: 100%;
		padding: 0.65rem 0.75rem;
		border: 1px solid #d1d5db;
		border-radius: 8px;
		background: #fff;
		font-size: 0.92rem;
		color: #111827;
	}

	.copy-button {
		white-space: nowrap;
	}

	.api-note {
		margin: 0.8rem 0 0;
		color: #4b5563;
		font-size: 0.92rem;
	}

	@media (max-width: 640px) {
		.api-url-row {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const STORAGE_KEY = "dogeared:myreads";
	const UPDATES_KEY = "dogeared:updates";
	const USER_KEY_STORAGE_KEY = "dogeared:user-key";
	const importForm = document.getElementById("goodreads-import-form");
	const csvInput = document.getElementById("goodreads-csv");
	const feedback = document.getElementById("import-feedback");
	const summary = document.getElementById("import-summary");
	const accountFeedback = document.getElementById("account-feedback");
	const accountSignedInState = document.getElementById("account-signed-in-state");
	const accountDangerZone = document.getElementById("account-danger-zone");
	const accountEmail = document.getElementById("account-email");
	const magicLinkForm = document.getElementById("magic-link-form");
	const magicEmail = document.getElementById("magic-email");
	const logoutButton = document.getElementById("logout-button");
	const deleteAccountForm = document.getElementById("delete-account-form");
	const deleteConfirm = document.getElementById("delete-confirm");
	const apiFeedback = document.getElementById("api-feedback");
	const shelfApiInput = document.getElementById("api-shelf-url");
	const searchApiInput = document.getElementById("api-search-url");
	const topApiInput = document.getElementById("api-top-url");
	const exportFeedback = document.getElementById("export-feedback");
	const downloadDataButton = document.getElementById("download-data-button");
	const clearShelfButton = document.getElementById("clear-shelf-button");
	const preferredExportFormat = document.getElementById("preferred-export-format");
	const preferencesFeedback = document.getElementById("preferences-feedback");
	const savePreferencesButton = document.getElementById("save-preferences-button");
	const importModeSelect = document.getElementById("import-mode");
	const importDryRunFirst = document.getElementById("import-dry-run-first");
	const previewImportButton = document.getElementById("preview-import-button");
	const importControlsFeedback = document.getElementById("import-controls-feedback");
	const profileVisibilitySelect = document.getElementById("profile-visibility");
	const shareLocationCheckbox = document.getElementById("share-location");
	const shareActivityCheckbox = document.getElementById("share-activity");
	const defaultShelfSelect = document.getElementById("default-shelf");
	const homeSortSelect = document.getElementById("home-sort");
	const favoriteGenresInput = document.getElementById("favorite-genres-input");
	const excludedGenresInput = document.getElementById("excluded-genres-input");
	const refreshSecurityButton = document.getElementById("refresh-security-button");
	const revokeSessionsButton = document.getElementById("revoke-sessions-button");
	const sessionList = document.getElementById("session-list");
	const recentActivityList = document.getElementById("recent-activity-list");
	const securityFeedback = document.getElementById("security-feedback");
	const copyButtons = Array.from(document.querySelectorAll(".copy-button"));

	function showFeedback(message, isError = false) {
		feedback.textContent = message;
		feedback.hidden = false;
		feedback.classList.toggle("error", isError);
	}

	function showSummary(result) {
		summary.innerHTML = `
			<p><strong>Imported:</strong> ${result.imported} books</p>
			<p><strong>Updated:</strong> ${result.updated} books</p>
			<p><strong>Skipped:</strong> ${result.skipped} rows</p>
			<p><strong>Shelves:</strong> Want to Read (${result.wantToRead}), Currently Reading (${result.reading}), Read (${result.finished})</p>
		`;
		summary.hidden = false;
	}

	function showAccountFeedback(message, isError = false) {
		accountFeedback.textContent = message;
		accountFeedback.hidden = !message;
		accountFeedback.classList.toggle("error", isError);
	}

	function showApiFeedback(message, isError = false) {
		if (!(apiFeedback instanceof HTMLElement)) return;
		apiFeedback.textContent = message;
		apiFeedback.hidden = !message;
		apiFeedback.classList.toggle("error", isError);
	}

	function showExportFeedback(message, isError = false) {
		if (!(exportFeedback instanceof HTMLElement)) return;
		exportFeedback.textContent = message;
		exportFeedback.hidden = !message;
		exportFeedback.classList.toggle("error", isError);
	}

	function showPreferencesFeedback(message, isError = false) {
		if (!(preferencesFeedback instanceof HTMLElement)) return;
		preferencesFeedback.textContent = message;
		preferencesFeedback.hidden = !message;
		preferencesFeedback.classList.toggle("error", isError);
	}

	function showImportControlsFeedback(message, isError = false) {
		if (!(importControlsFeedback instanceof HTMLElement)) return;
		importControlsFeedback.textContent = message;
		importControlsFeedback.hidden = !message;
		importControlsFeedback.classList.toggle("error", isError);
	}

	function showSecurityFeedback(message, isError = false) {
		if (!(securityFeedback instanceof HTMLElement)) return;
		securityFeedback.textContent = message;
		securityFeedback.hidden = !message;
		securityFeedback.classList.toggle("error", isError);
	}

	function normalizeText(value) {
		return String(value || "").trim();
	}

	function normalizeNumber(value) {
		const n = Number(value);
		if (!Number.isFinite(n) || n < 0) return 0;
		return Math.floor(n);
	}

	function normalizeIsbn(value) {
		return String(value || "").replace(/[^0-9Xx]/g, "").toUpperCase();
	}

	function coverFromIsbn(isbn13, isbn10, size = "M") {
		const clean13 = normalizeIsbn(isbn13);
		const clean10 = normalizeIsbn(isbn10);
		if (clean13.length === 13) return `https://covers.openlibrary.org/b/isbn/${clean13}-${size}.jpg`;
		if (clean10.length === 10) return `https://covers.openlibrary.org/b/isbn/${clean10}-${size}.jpg`;
		return "";
	}

	function canonicalizeTitle(value) {
		return normalizeText(value)
			.toLowerCase()
			.normalize("NFKD")
			.replace(/[\u0300-\u036f]/g, "")
			.replace(/\([^)]*\)/g, " ")
			.replace(/\b(abridged|unabridged|audio ?book|audiobook|kindle edition|paperback|hardcover|ebook|e-book|digital edition|color edition)\b/g, " ")
			.split(":")[0]
			.replace(/^(the|a|an)\s+/g, "")
			.replace(/[^a-z0-9\s]/g, " ")
			.replace(/\s+/g, " ")
			.trim();
	}

	function canonicalizeAuthor(value) {
		return normalizeText(value)
			.toLowerCase()
			.normalize("NFKD")
			.replace(/[\u0300-\u036f]/g, "")
			.replace(/^(by\s+)/, "")
			.replace(/[^a-z0-9\s]/g, " ")
			.replace(/\s+/g, " ")
			.trim();
	}

	function canonicalWorkKey(entry) {
		const isbn13 = normalizeIsbn(entry.isbn13);
		const isbn10 = normalizeIsbn(entry.isbn10);
		if (isbn13) return `isbn13:${isbn13}`;
		if (isbn10) return `isbn10:${isbn10}`;
		return `title_author:${canonicalizeTitle(entry.title)}|${canonicalizeAuthor(entry.author)}`;
	}

	function parseCsv(text) {
		const rows = [];
		let row = [];
		let cell = "";
		let inQuotes = false;

		for (let i = 0; i < text.length; i += 1) {
			const char = text[i];
			const next = text[i + 1];

			if (char === '"') {
				if (inQuotes && next === '"') {
					cell += '"';
					i += 1;
				} else {
					inQuotes = !inQuotes;
				}
				continue;
			}

			if (!inQuotes && char === ",") {
				row.push(cell);
				cell = "";
				continue;
			}

			if (!inQuotes && (char === "\n" || char === "\r")) {
				if (char === "\r" && next === "\n") i += 1;
				row.push(cell);
				rows.push(row);
				row = [];
				cell = "";
				continue;
			}

			cell += char;
		}

		if (cell.length > 0 || row.length > 0) {
			row.push(cell);
			rows.push(row);
		}

		return rows;
	}

	function toHeaderMap(headers) {
		const map = new Map();
		headers.forEach((header, index) => {
			map.set(normalizeText(header).toLowerCase(), index);
		});
		return map;
	}

	function getValue(row, headerMap, headerName) {
		const index = headerMap.get(headerName.toLowerCase());
		if (index === undefined) return "";
		return normalizeText(row[index]);
	}

	function mapGoodreadsShelfToStatus(value) {
		const shelf = normalizeText(value).toLowerCase();
		if (shelf === "currently-reading") return "reading";
		if (shelf === "read") return "finished";
		return "want_to_read";
	}

	const NON_GENRE_SHELVES = new Set([
		"",
		"all",
		"book-club",
		"books-i-own",
		"default",
		"did-not-finish",
		"dnf",
		"faves",
		"favorites",
		"fiction",
		"general",
		"kindle",
		"library",
		"maybe",
		"owned",
		"physical",
		"read",
		"re-read",
		"reread",
		"tbr",
		"to-buy",
		"to-read",
		"currently-reading",
		"want-to-buy",
		"want-to-own"
	]);

	function slugifyShelf(value) {
		return normalizeText(value)
			.toLowerCase()
			.replace(/[^a-z0-9]+/g, "-")
			.replace(/^-+|-+$/g, "");
	}

	function isGenreShelf(slug) {
		if (!slug || NON_GENRE_SHELVES.has(slug)) return false;
		if (/^\d{4}(-reads)?$/.test(slug)) return false;
		if (/^\d+$/.test(slug)) return false;
		return true;
	}

	function parseGenres(value) {
		if (!value) return [];
		return value.split(",")
			.map((item) => normalizeText(item))
			.filter((item) => isGenreShelf(slugifyShelf(item)));
	}

	function parseDate(value) {
		const text = normalizeText(value);
		if (!text) return "";
		const parsed = new Date(text);
		if (!Number.isFinite(parsed.getTime())) return "";
		return parsed.toISOString().slice(0, 10);
	}

	function loadEntries() {
		try {
			const parsed = JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
			return Array.isArray(parsed) ? parsed : [];
		} catch {
			return [];
		}
	}

	function saveEntries(entries) {
		localStorage.setItem(STORAGE_KEY, JSON.stringify(entries));
	}

	function isQuotaExceededError(error) {
		if (!error) return false;
		if (typeof DOMException !== "undefined" && error instanceof DOMException) {
			return error.name === "QuotaExceededError" || error.name === "NS_ERROR_DOM_QUOTA_REACHED";
		}
		const name = String(error?.name || "");
		const message = String(error?.message || "");
		return name.includes("Quota") || message.toLowerCase().includes("quota");
	}

	function compactEntry(entry) {
		const categories = Array.isArray(entry?.categories) ? entry.categories.slice(0, 8) : [];
		return {
			id: normalizeText(entry?.id),
			title: normalizeText(entry?.title),
			author: normalizeText(entry?.author),
			status: normalizeText(entry?.status) || "want_to_read",
			rating: Number.isFinite(Number(entry?.rating)) ? Number(entry.rating) : 0,
			totalPages: normalizeNumber(entry?.totalPages),
			currentPage: normalizeNumber(entry?.currentPage),
			finishedDate: normalizeText(entry?.finishedDate),
			coverUrl: normalizeText(entry?.coverUrl),
			format: normalizeText(entry?.format),
			language: normalizeText(entry?.language),
			publisher: normalizeText(entry?.publisher),
			publishedDate: normalizeText(entry?.publishedDate),
			isbn10: normalizeIsbn(entry?.isbn10),
			isbn13: normalizeIsbn(entry?.isbn13),
			categories,
			updatedAt: normalizeNumber(entry?.updatedAt) || Date.now()
		};
	}

	function saveEntriesWithFallback(entries) {
		try {
			saveEntries(entries);
			return "full";
		} catch (error) {
			if (!isQuotaExceededError(error)) throw error;
		}

		const compact = entries.map(compactEntry);
		const limits = [compact.length, 2000, 1500, 1000, 700, 500, 300];
		for (const limit of limits) {
			const subset = compact.slice(0, Math.min(limit, compact.length));
			try {
				saveEntries(subset);
				return subset.length === entries.length ? "compact" : "trimmed";
			} catch (error) {
				if (!isQuotaExceededError(error)) throw error;
			}
		}
		return "failed";
	}

	function loadUpdates() {
		try {
			const parsed = JSON.parse(localStorage.getItem(UPDATES_KEY) || "[]");
			return Array.isArray(parsed) ? parsed : [];
		} catch {
			return [];
		}
	}

	function saveUpdates(updates) {
		const candidates = [200, 120, 80, 40, 20];
		for (const limit of candidates) {
			try {
				localStorage.setItem(UPDATES_KEY, JSON.stringify(updates.slice(0, limit)));
				return true;
			} catch (error) {
				if (!isQuotaExceededError(error)) return false;
			}
		}
		return false;
	}

	function logShelfUpdate(entry, status) {
		if (!entry?.title) return;
		const updates = loadUpdates();
		updates.unshift({
			id: `upd_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
			timestamp: Date.now(),
			status: status || entry.status || "want_to_read",
			title: entry.title,
			author: entry.author || "",
			coverUrl: entry.coverUrl || "",
			format: entry.format || "",
			language: entry.language || ""
		});
		void saveUpdates(updates);
	}

	function getUserKey() {
