---
import LeftHand from '../components/LeftHand.astro';
type SectionLink = { id: string; label: string };
const { title = "Dogeared", sectionLinks = [] } = Astro.props as { title?: string; sectionLinks?: SectionLink[] };
const currentPath = Astro.url.pathname;
import '../assets/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Google Analytics: Only load in production -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-RT7DKML8JY"></script>
		<script is:inline>
			if (
				typeof window !== "undefined" &&
				!['localhost', '127.0.0.1'].includes(window.location.hostname)
			) {
				// @ts-ignore
				window.dataLayer = window.dataLayer || [];
				// @ts-ignore
				function gtag(){dataLayer.push(arguments);}
				// @ts-ignore
				gtag('js', new Date());
				// @ts-ignore
				gtag('config', 'G-RT7DKML8JY');
			}
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Dogeared</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Chewy&family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Permanent+Marker&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
	</head>
		<body>
			<div class="container">
				<div class="column" style="padding-bottom: 0;">
					<slot name="left">
						<LeftHand current={currentPath} sectionLinks={sectionLinks} />
					</slot>
				</div>
				<div class="column">
					<slot name="right">
						<slot />
					</slot>
				</div>
			</div>
			<a class="global-support-float" href="https://buymeacoffee.com/wylie" target="_blank" rel="noopener noreferrer">Support Dogeared</a>
		</body>
	</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;

	}
	.container {
		max-width: 1200px;
		margin: auto;
		display: grid;
		grid-template-columns: minmax(240px, 26%) minmax(0, 1fr);
		min-height: 100vh;
		align-items: start;
	}
	.column {
		display: flex;
		flex-direction: column;
	}
	.column {
		padding: 1rem;
	}
	.container > .column:first-child {
		position: sticky;
		top: 0;
		align-self: start;
		height: 100vh;
		overflow-y: auto;
	}
	.global-support-float {
		position: fixed;
		right: 1rem;
		bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
		z-index: 9999;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		background: #151515;
		color: #fff;
		border-radius: 999px;
		padding: 0.6rem 0.9rem;
		font-size: 0.9rem;
		font-weight: 700;
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}
	.global-support-float:hover {
		background: #2f8f57;
	}
	@media (max-width: 900px) {
		.container {
			max-width: 100%;
			grid-template-columns: 1fr;
			padding: 0 0.5rem 1rem;
			box-sizing: border-box;
		}
		.column {
			padding: 0.6rem 0.5rem;
		}
		.container > .column:first-child {
			position: static;
			top: auto;
			height: auto;
			overflow: visible;
		}
		.global-support-float {
			right: 0.6rem;
			bottom: calc(4.25rem + env(safe-area-inset-bottom, 0px));
			padding: 0.52rem 0.76rem;
			font-size: 0.84rem;
		}
	}
</style>
