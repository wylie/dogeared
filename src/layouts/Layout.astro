---
import LeftHand from '../components/LeftHand.astro';
type SectionLink = { id: string; label: string };
const { title = "DogEared", sectionLinks = [] } = Astro.props as { title?: string; sectionLinks?: SectionLink[] };
const currentPath = Astro.url.pathname;
import '../assets/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Google Analytics: Only load in production -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-RT7DKML8JY"></script>
		<script is:inline>
			if (
				typeof window !== "undefined" &&
				!['localhost', '127.0.0.1'].includes(window.location.hostname)
			) {
				// @ts-ignore
				window.dataLayer = window.dataLayer || [];
				// @ts-ignore
				function gtag(){dataLayer.push(arguments);}
				// @ts-ignore
				gtag('js', new Date());
				// @ts-ignore
				gtag('config', 'G-RT7DKML8JY');
			}
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | DogEared</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Chewy&family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Permanent+Marker&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
	</head>
		<body>
			<div class="container">
				<div class="column" style="padding-bottom: 0;">
					<slot name="left">
						<LeftHand current={currentPath} sectionLinks={sectionLinks} />
					</slot>
				</div>
				<div class="column">
					<slot name="right">
						<slot />
					</slot>
				</div>
			</div>
		</body>
	</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;

	}
	.container {
		max-width: 1200px;
		margin: auto;
		display: grid;
		grid-template-columns: 25% auto;
		min-height: 100vh;
		align-items: start;
	}
	.column {
		display: flex;
		flex-direction: column;
	}
	.column {
		padding: 1rem;
	}
	.container > .column:first-child {
		position: sticky;
		top: 0;
		align-self: start;
		height: 100vh;
		overflow-y: auto;
	}
</style>
