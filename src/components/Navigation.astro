---
const { current = "/" } = Astro.props;
const normalize = (path: string) => (path.length > 1 ? path.replace(/\/+$/, "") : path);
const isActive = (href: string) => normalize(current) === normalize(href);
---

<nav aria-label="Primary">
  <ul>
    <li><a href="/" class="special-font">DogEared</a></li>
    <li><a href={isActive('/browse') ? undefined : '/browse'} class={isActive('/browse') ? 'active' : 'hover'} aria-current={isActive('/browse') ? 'page' : undefined}>Browse</a></li>
    <li><input type="search" /></li>
    <li class="material-icons"><a href={isActive('/profile') ? undefined : '/profile'} class={isActive('/profile') ? 'active' : 'hover'} aria-current={isActive('/profile') ? 'page' : undefined}>person</a></li>
  </ul>
</nav>

<style>
  nav {
    padding: 1rem;
  }
  nav ul {
    list-style-type: none;
    display: flex;
    margin: 0;
    padding: 0;
    justify-content: space-between;
  }
  nav li {
    justify-content: center;
    display: flex;
    width: 100%;
  }
  nav a {
    text-decoration: none;
    color: black;
    padding: .75rem;
    border-radius: 5px;
  }
  nav a.active {
    background-color: #ddd;
    cursor: default;
  }
  nav .hover:hover {
    background-color: black;
    color: white;
  }
  nav input[type="search"] {
    font-size: 16px;
  }
</style>
